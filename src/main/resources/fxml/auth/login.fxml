<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.media.MediaView?>
<?import java.net.URL?>
<?import javafx.geometry.Insets?>

<StackPane fx:id="mainStackPane" styleClass="samurai-root" 
           xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="ma.ensa.khouribga.smartstay.auth.LoginController">
    
    <stylesheets>
        <URL value="@/styles/samurai.css" />
    </stylesheets>

    <MediaView fx:id="mediaView" preserveRatio="false" />
    
    <StackPane styleClass="main-overlay">
        
        <Pane fx:id="animationPane" mouseTransparent="true" />

        <AnchorPane>
            <VBox spacing="40" alignment="CENTER_LEFT" maxWidth="400" 
                  styleClass="glass-box" 
                  AnchorPane.leftAnchor="100.0" 
                  AnchorPane.topAnchor="150.0" AnchorPane.bottomAnchor="150.0">
                
                <Label text="SECURE ACCESS" style="-fx-text-fill: rgba(255,255,255,0.6); -fx-letter-spacing: 3px;"/>
                
                <VBox spacing="20">
                    <VBox spacing="8">
                        <Label text="USERNAME" style="-fx-text-fill: white; -fx-font-size: 11px;"/>
                        <TextField fx:id="usernameField" promptText="Your identity..." />
                    </VBox>
                    <VBox spacing="8">
                        <Label text="PASSWORD" style="-fx-text-fill: white; -fx-font-size: 11px;"/>
                        <PasswordField fx:id="passwordField" promptText="Your secret sign..." />
                    </VBox>
                </VBox>

                <Button text="SIGN IN" onAction="#onLogin" styleClass="samurai-button" maxWidth="Infinity"/>
                <Label fx:id="messageLabel" style="-fx-text-fill: #FFB7C5;"/>
            </VBox>

            <VBox alignment="BOTTOM_RIGHT" spacing="0" 
                  AnchorPane.bottomAnchor="80.0" AnchorPane.rightAnchor="100.0">
                <Label text="SmartStay" styleClass="app-title"/>
                <Label text="PROPERTY MANAGEMENT SYSTEM" styleClass="app-subtitle"/>
                <Label text="Khouribga Edition • 2026" style="-fx-text-fill: rgba(255,255,255,0.3);"/>
            </VBox>
        </AnchorPane>
    </StackPane>
</StackPane>