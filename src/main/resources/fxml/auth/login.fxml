<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.media.MediaView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.geometry.Insets?>

<StackPane
    xmlns="http://javafx.com/javafx/21"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="ma.ensa.khouribga.smartstay.auth.LoginController"
    prefWidth="1100" prefHeight="700"
    styleClass="samurai-root"
    stylesheets="@/styles/samurai.css">

    <!-- LAYER 1 - Video background fills entire root -->
    <Pane fx:id="particlePane" styleClass="particle-pane"
          maxWidth="Infinity" maxHeight="Infinity">
        <MediaView
            fx:id="mediaView"
            preserveRatio="false"
            mouseTransparent="true"/>
    </Pane>

    <!-- LAYER 2 - Vertical brand stripe (left) -->
    <HBox maxWidth="Infinity" maxHeight="Infinity"
          mouseTransparent="true" alignment="CENTER_LEFT">
        <VBox fx:id="brandStripe" alignment="CENTER" spacing="18"
              styleClass="brand-strip-inner" maxHeight="Infinity">
            <Label text="&#26234;" styleClass="kanji-large"/>
            <Label text="&#23431;" styleClass="kanji-large"/>
            <Separator styleClass="brand-divider"/>
            <Label text="S&#10;M&#10;A&#10;R&#10;T&#10;S&#10;T&#10;A&#10;Y"
                   styleClass="brand-vertical-text"/>
        </VBox>
    </HBox>

    <!-- LAYER 3 - Glass login card (center-right) -->
    <HBox alignment="CENTER_RIGHT" maxWidth="Infinity" maxHeight="Infinity">
        <HBox.margin>
            <Insets right="120"/>
        </HBox.margin>

        <VBox fx:id="glassCard" styleClass="glass-box" alignment="CENTER" spacing="0">
            <padding>
                <Insets top="52" right="50" bottom="48" left="50"/>
            </padding>

            <!-- Crest -->
            <Label text="&#9961;" styleClass="crest-icon"/>

            <!-- App title -->
            <Label text="SmartStay PMS" styleClass="app-title"/>
            <Label text="Khouribga Edition" styleClass="app-subtitle"/>

            <!-- Decorative rule -->
            <Pane styleClass="title-rule" prefHeight="1" prefWidth="260"/>

            <!-- Username -->
            <VBox spacing="6" styleClass="field-group">
                <VBox.margin><Insets top="36"/></VBox.margin>
                <Label text="USERNAME" styleClass="field-label"/>
                <TextField
                    fx:id="usernameField"
                    promptText="enter username"
                    styleClass="text-field"/>
            </VBox>

            <!-- Password -->
            <VBox spacing="6" styleClass="field-group">
                <VBox.margin><Insets top="20"/></VBox.margin>
                <Label text="PASSWORD" styleClass="field-label"/>
                <PasswordField
                    fx:id="passwordField"
                    promptText="&#8226;&#8226;&#8226;&#8226;&#8226;&#8226;&#8226;&#8226;"
                    styleClass="password-field"
                    onAction="#onLogin"/>
            </VBox>

            <!-- Error label -->
            <Label
                fx:id="errorLabel"
                text=""
                styleClass="error-label"
                visible="false"
                wrapText="true"
                maxWidth="260">
                <VBox.margin><Insets top="14"/></VBox.margin>
            </Label>

            <!-- Login button -->
            <Button
                text="ENTER THE DOJO  &#8594;"
                styleClass="samurai-button"
                onAction="#onLogin"
                defaultButton="true"
                maxWidth="Infinity">
                <VBox.margin><Insets top="28"/></VBox.margin>
            </Button>

            <!-- Footer -->
            <Label text="&#20581;  Samurai Protocol  &#20581;" styleClass="footer-label">
                <VBox.margin><Insets top="32"/></VBox.margin>
            </Label>

        </VBox>
    </HBox>

</StackPane>