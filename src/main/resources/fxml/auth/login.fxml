<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.media.MediaView?>
<?import javafx.geometry.Insets?>

<StackPane styleClass="samurai-root" stylesheets="@/styles/samurai.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ma.ensa.khouribga.smartstay.auth.LoginController">

    <MediaView fx:id="bgVideo" fitWidth="1920" fitHeight="1080" preserveRatio="false" />

    <VBox alignment="CENTER" spacing="0" maxWidth="450" maxHeight="550">
        <VBox styleClass="glass-box" alignment="CENTER" spacing="25" style="-fx-padding: 40;">
            
            <VBox alignment="CENTER" spacing="5">
                <Label text="侍" styleClass="kanji-large" style="-fx-font-size: 48px;"/>
                <Label text="SMARTSTAY" styleClass="app-title"/>
                <Label text="PROPERTY MANAGEMENT SYSTEM" styleClass="app-subtitle"/>
                <Separator styleClass="brand-divider" maxWidth="150" style="-fx-background-color: transparent; -fx-border-color: #c5a059; -fx-border-width: 1px 0 0 0; -fx-padding: 10 0 0 0;"/>
            </VBox>

            <VBox fx:id="loginPanel" spacing="20" maxWidth="350" alignment="CENTER_LEFT">
                <VBox spacing="5" styleClass="field-group">
                    <Label text="USERNAME / IDENTIFIER" styleClass="field-label"/>
                    <TextField fx:id="txtUsername" promptText="Enter your identifier..." styleClass="text-field"/>
                </VBox>

                <VBox spacing="5" styleClass="field-group">
                    <Label text="PASSWORD" styleClass="field-label"/>
                    <PasswordField fx:id="txtPassword" promptText="Enter your passcode..." styleClass="password-field"/>
                </VBox>

                <Label fx:id="lblError" styleClass="error-label" visible="false" managed="false"/>

                <Button text="AUTHENTICATE" onAction="#handleLogin" styleClass="btn-primary, samurai-button" maxWidth="Infinity" style="-fx-padding: 12 0;"/>
                
                <HBox alignment="CENTER" spacing="5" style="-fx-padding: 10 0 0 0;">
                    <Label text="New Guest?" styleClass="label-muted"/>
                    <Button text="Create an Account" onAction="#toggleRegister" styleClass="btn-link"/>
                </HBox>
            </VBox>

            <VBox fx:id="registerPanel" spacing="15" maxWidth="350" alignment="CENTER_LEFT" visible="false" managed="false">
                <HBox spacing="10">
                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                        <Label text="FIRST NAME" styleClass="field-label"/>
                        <TextField fx:id="txtRegFirst" styleClass="text-field"/>
                    </VBox>
                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                        <Label text="LAST NAME" styleClass="field-label"/>
                        <TextField fx:id="txtRegLast" styleClass="text-field"/>
                    </VBox>
                </HBox>

                <VBox spacing="5">
                    <Label text="EMAIL ADDRESS" styleClass="field-label"/>
                    <TextField fx:id="txtRegEmail" styleClass="text-field"/>
                </VBox>

                <VBox spacing="5">
                    <Label text="USERNAME" styleClass="field-label"/>
                    <TextField fx:id="txtRegUser" styleClass="text-field"/>
                </VBox>

                <VBox spacing="5">
                    <Label text="SECURE PASSWORD" styleClass="field-label"/>
                    <PasswordField fx:id="txtRegPass" styleClass="password-field"/>
                </VBox>

                <Button text="REGISTER IDENTITY" onAction="#handleRegister" styleClass="btn-primary, samurai-button" maxWidth="Infinity" style="-fx-padding: 12 0;"/>
                
                <HBox alignment="CENTER" spacing="5">
                    <Label text="Already inducted?" styleClass="label-muted"/>
                    <Button text="Sign In" onAction="#toggleRegister" styleClass="btn-link"/>
                </HBox>
            </VBox>

        </VBox>
    </VBox>
</StackPane>