<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="ma.ensa.khouribga.smartstay.guest.RoomDetailController"
      styleClass="interior-root"
      spacing="0"
      prefWidth="640">

    <!-- ── Header bar ── -->
    <HBox styleClass="header-bar" alignment="CENTER_LEFT" spacing="12">
        <padding><Insets top="0" right="24" bottom="0" left="24"/></padding>
        <Label fx:id="lblRoomNumber" text="Room —" styleClass="welcome-label"/>
        <Label fx:id="lblRoomType"   text=""        styleClass="label-muted"/>
    </HBox>

    <!-- ── Body ── -->
    <HBox spacing="20" VBox.vgrow="ALWAYS">
        <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

        <!-- Left column: room details -->
        <VBox spacing="14" HBox.hgrow="ALWAYS">

            <VBox styleClass="card" spacing="10">
                <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>

                <Label text="Room Details" styleClass="section-title"/>

                <GridPane hgap="12" vgap="8">
                    <Label text="Floor:"        GridPane.columnIndex="0" GridPane.rowIndex="0" styleClass="form-label"/>
                    <Label fx:id="lblFloor"     GridPane.columnIndex="1" GridPane.rowIndex="0" styleClass="interior-text-field" style="-fx-padding:0;"/>

                    <Label text="Occupancy:"         GridPane.columnIndex="0" GridPane.rowIndex="1" styleClass="form-label"/>
                    <Label fx:id="lblMaxOccupancy"   GridPane.columnIndex="1" GridPane.rowIndex="1" styleClass="interior-text-field" style="-fx-padding:0;"/>

                    <Label text="Rate:"         GridPane.columnIndex="0" GridPane.rowIndex="2" styleClass="form-label"/>
                    <Label fx:id="lblPrice"     GridPane.columnIndex="1" GridPane.rowIndex="2"
                           styleClass="room-card-price" style="-fx-padding:0;"/>
                </GridPane>

                <Separator/>

                <Label text="Amenities" styleClass="form-label"/>
                <Label fx:id="lblAmenities" wrapText="true"
                       style="-fx-text-fill:#aaa; -fx-font-size:12px;"/>

                <Label text="Description" styleClass="form-label"/>
                <TextArea fx:id="taDescription" styleClass="text-area"
                          prefRowCount="4" editable="false" wrapText="true"/>
            </VBox>
        </VBox>

        <!-- Right column: date selection + summary -->
        <VBox spacing="14" prefWidth="240">

            <VBox styleClass="card" spacing="12">
                <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>

                <Label text="Select Dates" styleClass="section-title"/>

                <Label text="Check-in" styleClass="form-label"/>
                <DatePicker fx:id="dpCheckIn" styleClass="date-picker" maxWidth="Infinity"/>

                <Label text="Check-out" styleClass="form-label"/>
                <DatePicker fx:id="dpCheckOut" styleClass="date-picker" maxWidth="Infinity"/>

                <Separator/>

                <GridPane hgap="8" vgap="6">
                    <Label text="Nights:"      GridPane.columnIndex="0" GridPane.rowIndex="0" styleClass="form-label"/>
                    <Label fx:id="lblNights"   GridPane.columnIndex="1" GridPane.rowIndex="0"
                           style="-fx-text-fill:#e2c97e; -fx-font-weight:bold;"/>

                    <Label text="Subtotal:"    GridPane.columnIndex="0" GridPane.rowIndex="1" styleClass="form-label"/>
                    <Label fx:id="lblSubtotal" GridPane.columnIndex="1" GridPane.rowIndex="1"
                           style="-fx-text-fill:#e2c97e; -fx-font-weight:bold;"/>
                </GridPane>

                <Label fx:id="lblError" styleClass="error-label" wrapText="true"/>
            </VBox>

            <!-- Actions -->
            <Button fx:id="btnBook" text="Proceed to Payment →"
                    styleClass="btn-primary" maxWidth="Infinity"
                    onAction="#handleBook"/>
            <Button fx:id="btnCancel" text="Cancel"
                    styleClass="btn-secondary" maxWidth="Infinity"
                    onAction="#handleCancel"/>
        </VBox>
    </HBox>

</VBox>
