<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.media.MediaView?>
<?import javafx.scene.layout.StackPane?>

<StackPane styleClass="video-root" stylesheets="@/styles/samurai.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ma.ensa.khouribga.smartstay.profile.AdminProfileController">
    <MediaView fx:id="bgMediaView" mouseTransparent="true"
               preserveRatio="false" style="-fx-smooth: true;"/>
    <BorderPane styleClass="interior-root">

    <!-- ═══════════ SIDEBAR -->
    <left>
        <VBox styleClass="sidebar" prefWidth="220" spacing="4">
            <VBox styleClass="sidebar-header" alignment="CENTER" spacing="4">
                <Label text="侍" styleClass="sidebar-logo"/>
                <Label text="SMARTSTAY" styleClass="app-title"/>
                <Label text="ADMINISTRATOR" styleClass="app-subtitle"/>
                <Label text="智 Wisdom · 侍 Precision" styleClass="sidebar-sub-kanji"/>
            </VBox>
            <Button text="⛩  Dashboard"   styleClass="nav-button" maxWidth="Infinity"/>
            <Button text="👤  Profile"      styleClass="nav-button-active" maxWidth="Infinity"/>
            <Region VBox.vgrow="ALWAYS"/>
            <HBox alignment="CENTER" style="-fx-padding: 0 16 8 16;">
                <Button text="☀ Light" onAction="#handleThemeToggle" styleClass="btn-theme" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
            </HBox>
            <VBox style="-fx-padding: 0 16 16 16;">
                <Button text="LOGOUT" onAction="#handleLogout" styleClass="btn-logout" maxWidth="Infinity"/>
            </VBox>
        </VBox>
    </left>

    <!-- ═══════════ HEADER BAR -->
    <top>
        <HBox styleClass="header-bar" alignment="CENTER_LEFT" spacing="16">
            <Button text="← Return to Command Center" onAction="#goBack" styleClass="btn-secondary"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="Shogun Profile" styleClass="section-title" style="-fx-font-size: 22px;"/>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" styleClass="scroll-pane">
            <HBox spacing="30" alignment="TOP_CENTER" style="-fx-padding: 30;">

                <!-- Avatar card -->
                <VBox styleClass="glass-box" spacing="15" alignment="CENTER" prefWidth="300" maxHeight="420">
                    <StackPane styleClass="avatar-circle" prefWidth="120" prefHeight="120" maxWidth="120" maxHeight="120">
                        <Label fx:id="lblInitials" text="AD" styleClass="avatar-initials" style="-fx-font-size: 48px;"/>
                    </StackPane>
                    <Label fx:id="lblUsername" text="System Admin" styleClass="card-header-text" style="-fx-font-size: 22px;"/>
                    <Label text="SHOGUN (ADMIN)" styleClass="badge, badge-occupied" style="-fx-font-size: 13px; -fx-padding: 6 15;"/>
                    <Region styleClass="gold-divider" maxWidth="200"/>
                    <VBox alignment="CENTER" spacing="5">
                        <Label text="System Access Level" styleClass="label-muted"/>
                        <Label text="Absolute (All Sectors Unlocked)" style="-fx-text-fill: #c5a059; -fx-font-weight: bold;"/>
                    </VBox>
                </VBox>

                <!-- Forms -->
                <VBox spacing="24" prefWidth="540">

                    <VBox styleClass="glass-box" spacing="18">
                        <Label text="Master Communications" styleClass="section-title" style="-fx-font-size: 18px;"/>
                        <Region styleClass="gold-divider"/>
                        <VBox spacing="5">
                            <Label text="IMPERIAL EMAIL ADDRESS" styleClass="field-label"/>
                            <TextField fx:id="txtEmail" promptText="Enter command email..." styleClass="text-field"/>
                        </VBox>
                        <Button text="UPDATE COMM LINK" onAction="#updateContact" styleClass="btn-primary" maxWidth="Infinity"/>
                    </VBox>

                    <VBox styleClass="glass-box" spacing="18">
                        <Label text="Authentication Protocol" styleClass="section-title" style="-fx-font-size: 18px;"/>
                        <Region styleClass="gold-divider"/>
                        <VBox spacing="5">
                            <Label text="CURRENT PASSPHRASE" styleClass="field-label"/>
                            <PasswordField fx:id="txtOldPass" promptText="Verify current identity..." styleClass="password-field"/>
                        </VBox>
                        <HBox spacing="14">
                            <VBox spacing="5" HBox.hgrow="ALWAYS">
                                <Label text="NEW PASSPHRASE" styleClass="field-label"/>
                                <PasswordField fx:id="txtNewPass" promptText="At least 8 characters..." styleClass="password-field"/>
                            </VBox>
                            <VBox spacing="5" HBox.hgrow="ALWAYS">
                                <Label text="CONFIRM PASSPHRASE" styleClass="field-label"/>
                                <PasswordField fx:id="txtConfirmPass" promptText="Type it again..." styleClass="password-field"/>
                            </VBox>
                        </HBox>
                        <Button text="CHANGE MASTER PASSPHRASE" onAction="#updatePassword" styleClass="btn-danger" maxWidth="Infinity"/>
                    </VBox>
                </VBox>

            </HBox>
        </ScrollPane>
    </center>
</BorderPane>
</StackPane>
