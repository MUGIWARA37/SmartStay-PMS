<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.media.MediaView?>

<StackPane styleClass="video-root" stylesheets="@/styles/samurai.css"
           xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="ma.ensa.khouribga.smartstay.profile.AdminProfileController">
    <MediaView fx:id="bgMediaView" mouseTransparent="true" preserveRatio="false"/>

    <BorderPane styleClass="interior-root">

        <!-- ══════════════════════════════════ SIDEBAR
             Full admin nav — same items as admin.fxml.
             Each calls Navigator.navigateTo() back to admin.fxml
             (goBack() already does this for the back button).
             Nav items here navigate away; Settings is active (current screen).
        -->
        <left>
            <VBox styleClass="sidebar" prefWidth="250" spacing="0">

                <VBox styleClass="sidebar-header" alignment="CENTER" spacing="4"
                      style="-fx-padding: 28 16 24 16;">
                    <Label text="侍" styleClass="sidebar-logo"/>
                    <Label text="SMARTSTAY"     styleClass="app-title"/>
                    <Label text="ADMINISTRATOR" styleClass="app-subtitle"/>
                    <Label text="智 Wisdom · 侍 Precision"
                           styleClass="sidebar-sub-kanji"/>
                </VBox>

                <!-- Navigate back to admin dashboard (goBack returns to admin.fxml) -->
                <Button text="⛩  Dashboard"
                        onAction="#goBack"
                        styleClass="nav-button" maxWidth="Infinity"/>
                <Button text="🏯  Room Mastery"
                        onAction="#goBack"
                        styleClass="nav-button" maxWidth="Infinity"/>
                <Button text="📋  Guest Scrolls"
                        onAction="#goBack"
                        styleClass="nav-button" maxWidth="Infinity"/>
                <Button text="💴  Financial Katana"
                        onAction="#goBack"
                        styleClass="nav-button" maxWidth="Infinity"/>
                <Button text="👥  Zen Inventory"
                        onAction="#goBack"
                        styleClass="nav-button" maxWidth="Infinity"/>
                <!-- Settings / Profile is the current screen -->
                <Button text="⚙  Settings"
                        styleClass="nav-button-active" maxWidth="Infinity"/>

                <Region VBox.vgrow="ALWAYS"/>

                <HBox style="-fx-padding: 0 16 10 16;">
                    <Button text="☀ Light" onAction="#handleThemeToggle"
                            styleClass="btn-theme" maxWidth="Infinity"
                            HBox.hgrow="ALWAYS"/>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="10"
                      style="-fx-padding: 10 16 8 16;">
                    <StackPane styleClass="avatar-circle" prefWidth="34" prefHeight="34">
                        <Label fx:id="lblInitials" text="AD"
                               styleClass="avatar-initials"
                               style="-fx-font-size: 14px;"/>
                    </StackPane>
                    <VBox alignment="CENTER_LEFT" spacing="1">
                        <Label fx:id="lblUsername" text="System Admin"
                               style="-fx-text-fill:#e0e0e0;-fx-font-weight:bold;-fx-font-size:12px;"/>
                        <Label text="SHOGUN (ADMIN)"
                               styleClass="label-muted" style="-fx-font-size: 10px;"/>
                    </VBox>
                </HBox>
                <VBox style="-fx-padding: 4 16 20 16;">
                    <Button text="LOGOUT" onAction="#handleLogout"
                            styleClass="btn-logout" maxWidth="Infinity"/>
                </VBox>
            </VBox>
        </left>

        <!-- ══════════════════════════════════ HEADER -->
        <top>
            <HBox styleClass="header-bar" alignment="CENTER_LEFT" spacing="16">
                <Button text="← Return to Command Center"
                        onAction="#goBack" styleClass="btn-secondary"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="IMPERIAL PORTAL" styleClass="breadcrumb-label"/>
                <Label text="·" styleClass="label-muted"/>
                <Label text="Settings"
                       style="-fx-text-fill:#cc2222;-fx-font-size:11px;
                              -fx-font-weight:bold;-fx-letter-spacing:2;"/>
            </HBox>
        </top>

        <!-- ══════════════════════════════════ CENTER -->
        <center>
            <ScrollPane fitToWidth="true" styleClass="scroll-pane">
                <HBox spacing="28" alignment="TOP_CENTER"
                      style="-fx-padding: 28;">

                    <!-- Avatar card -->
                    <VBox styleClass="glass-box" spacing="16"
                          alignment="CENTER" prefWidth="290" maxHeight="400">
                        <StackPane styleClass="avatar-circle"
                                   prefWidth="110" prefHeight="110"
                                   maxWidth="110" maxHeight="110">
                            <Label text="AD" styleClass="avatar-initials"
                                   style="-fx-font-size: 44px;"/>
                        </StackPane>
                        <Label text="System Admin"
                               styleClass="card-header-text"
                               style="-fx-font-size: 20px;"/>
                        <Label text="SHOGUN (ADMIN)"
                               styleClass="badge, badge-occupied"
                               style="-fx-font-size: 12px; -fx-padding: 5 14;"/>
                        <Region styleClass="gold-divider" maxWidth="200"/>
                        <VBox alignment="CENTER" spacing="4">
                            <Label text="System Access Level"
                                   styleClass="label-muted"/>
                            <Label text="Absolute — All Sectors"
                                   style="-fx-text-fill:#c5a059;-fx-font-weight:bold;"/>
                        </VBox>
                    </VBox>

                    <!-- Edit forms -->
                    <VBox spacing="22" prefWidth="520">

                        <VBox styleClass="glass-box" spacing="16">
                            <Label text="Master Communications"
                                   styleClass="section-title"
                                   style="-fx-font-size: 17px;"/>
                            <Region styleClass="gold-divider"/>
                            <VBox spacing="5">
                                <Label text="IMPERIAL EMAIL ADDRESS"
                                       styleClass="field-label"/>
                                <TextField fx:id="txtEmail"
                                           promptText="Enter command email…"
                                           styleClass="text-field"/>
                            </VBox>
                            <Button text="UPDATE COMM LINK"
                                    onAction="#updateContact"
                                    styleClass="btn-primary"
                                    maxWidth="Infinity"/>
                        </VBox>

                        <VBox styleClass="glass-box" spacing="16">
                            <Label text="Authentication Protocol"
                                   styleClass="section-title"
                                   style="-fx-font-size: 17px;"/>
                            <Region styleClass="gold-divider"/>
                            <VBox spacing="5">
                                <Label text="CURRENT PASSPHRASE"
                                       styleClass="field-label"/>
                                <PasswordField fx:id="txtOldPass"
                                               promptText="Verify current identity…"
                                               styleClass="password-field"/>
                            </VBox>
                            <HBox spacing="14">
                                <VBox spacing="5" HBox.hgrow="ALWAYS">
                                    <Label text="NEW PASSPHRASE"
                                           styleClass="field-label"/>
                                    <PasswordField fx:id="txtNewPass"
                                                   promptText="At least 8 chars…"
                                                   styleClass="password-field"/>
                                </VBox>
                                <VBox spacing="5" HBox.hgrow="ALWAYS">
                                    <Label text="CONFIRM PASSPHRASE"
                                           styleClass="field-label"/>
                                    <PasswordField fx:id="txtConfirmPass"
                                                   promptText="Repeat…"
                                                   styleClass="password-field"/>
                                </VBox>
                            </HBox>
                            <Button text="CHANGE MASTER PASSPHRASE"
                                    onAction="#updatePassword"
                                    styleClass="btn-danger"
                                    maxWidth="Infinity"/>
                        </VBox>

                    </VBox>
                </HBox>
            </ScrollPane>
        </center>
    </BorderPane>
</StackPane>
