<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.media.MediaView?>
<?import javafx.scene.layout.StackPane?>

<StackPane styleClass="video-root" stylesheets="@/styles/samurai.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ma.ensa.khouribga.smartstay.profile.StaffProfileController">
    <MediaView fx:id="bgMediaView" mouseTransparent="true"
               preserveRatio="false" style="-fx-smooth: true;"/>
    <BorderPane styleClass="interior-root">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-padding: 30 40 10 40;">
            <Button text="← Return to Duty" onAction="#goBack" styleClass="btn-secondary"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="Retainer Profile" styleClass="section-title" style="-fx-font-size: 28px;"/>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" styleClass="scroll-pane" style="-fx-padding: 20;">
            <HBox spacing="30" alignment="TOP_CENTER">
                
                <VBox styleClass="glass-box" spacing="15" alignment="CENTER" prefWidth="320" minWidth="320">
                    <StackPane styleClass="avatar-circle" prefWidth="120" prefHeight="120" maxWidth="120" maxHeight="120">
                        <Label fx:id="lblInitials" text="ST" styleClass="avatar-initials" style="-fx-font-size: 48px;"/>
                    </StackPane>
                    
                    <Label fx:id="lblFullName" text="Loading..." styleClass="card-header-text" style="-fx-font-size: 24px;"/>
                    <Label fx:id="lblRole" text="STAFF MEMBER" styleClass="badge, badge-assigned" style="-fx-font-size: 14px; -fx-padding: 6 15;"/>
                    
                    <Separator style="-fx-padding: 10 0;"/>
                    
                    <GridPane hgap="10" vgap="15" alignment="CENTER_LEFT">
                        <columnConstraints>
                            <ColumnConstraints minWidth="100"/>
                            <ColumnConstraints hgrow="ALWAYS"/>
                        </columnConstraints>
                        
                        <Label text="POSITION:" styleClass="label-muted" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                        <Label fx:id="lblPosition" text="-" style="-fx-text-fill: #e0e0e0; -fx-font-weight: bold;" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                        
                        <Label text="DEPT:" styleClass="label-muted" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                        <Label fx:id="lblDepartment" text="-" style="-fx-text-fill: #e0e0e0;" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                        <Label text="CODE:" styleClass="label-muted" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                        <Label fx:id="lblEmpCode" text="-" style="-fx-text-fill: #c5a059;" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                        <Label text="HIRED:" styleClass="label-muted" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                        <Label fx:id="lblHireDate" text="-" style="-fx-text-fill: #e0e0e0;" GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                        <Label text="BASE WAGE:" styleClass="label-muted" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                        <Label fx:id="lblSalary" text="-" style="-fx-text-fill: #2ecc71; -fx-font-weight: bold;" GridPane.columnIndex="1" GridPane.rowIndex="4"/>
                    </GridPane>
                </VBox>

                <VBox spacing="25" HBox.hgrow="ALWAYS" maxWidth="800">
                    
                    <HBox spacing="25">
                        <VBox styleClass="glass-box" spacing="15" HBox.hgrow="ALWAYS">
                            <Label text="Communications" styleClass="section-title" style="-fx-font-size: 20px;"/>
                            <VBox spacing="5">
                                <Label text="EMAIL ADDRESS" styleClass="field-label"/>
                                <TextField fx:id="txtEmail" styleClass="text-field"/>
                            </VBox>
                            <VBox spacing="5">
                                <Label text="PHONE NUMBER" styleClass="field-label"/>
                                <TextField fx:id="txtPhone" styleClass="text-field"/>
                            </VBox>
                            <VBox spacing="5">
                                <Label text="EMERGENCY CONTACT" styleClass="field-label"/>
                                <TextField fx:id="txtEmergency" styleClass="text-field"/>
                            </VBox>
                            <Button text="UPDATE CONTACTS" onAction="#updateContact" styleClass="btn-primary" maxWidth="Infinity"/>
                        </VBox>

                        <VBox styleClass="glass-box" spacing="15" HBox.hgrow="ALWAYS">
                            <Label text="Security Protocol" styleClass="section-title" style="-fx-font-size: 20px;"/>
                            <VBox spacing="5">
                                <Label text="CURRENT PASSPHRASE" styleClass="field-label"/>
                                <PasswordField fx:id="txtOldPass" styleClass="password-field"/>
                            </VBox>
                            <VBox spacing="5">
                                <Label text="NEW PASSPHRASE" styleClass="field-label"/>
                                <PasswordField fx:id="txtNewPass" styleClass="password-field"/>
                            </VBox>
                            <VBox spacing="5">
                                <Label text="CONFIRM PASSPHRASE" styleClass="field-label"/>
                                <PasswordField fx:id="txtConfirmPass" styleClass="password-field"/>
                            </VBox>
                            <Button text="CHANGE PASSPHRASE" onAction="#updatePassword" styleClass="samurai-button" maxWidth="Infinity" style="-fx-border-color: #e74c3c; -fx-text-fill: #e74c3c; -fx-background-color: transparent;"/>
                        </VBox>
                    </HBox>

                    <VBox styleClass="glass-box" spacing="15">
                        <Label text="Duty Roster (This Week)" styleClass="section-title" style="-fx-font-size: 20px;"/>
                        <HBox fx:id="shiftsContainer" spacing="10" alignment="CENTER_LEFT">
                            </HBox>
                    </VBox>

                    <VBox styleClass="glass-box" spacing="15">
                        <Label text="Report System Anomaly" styleClass="section-title" style="-fx-font-size: 20px;"/>
                        <Label text="Directly alert maintenance to an issue anywhere in the compound." styleClass="label-muted"/>
                        
                        <VBox spacing="5">
                            <Label text="ANOMALY CLASSIFICATION" styleClass="field-label"/>
                            <ComboBox fx:id="cmbIssueCategory" promptText="Select Classification..." styleClass="combo-box" maxWidth="Infinity"/>
                        </VBox>

                        <VBox spacing="5">
                            <Label text="ANOMALY DESCRIPTION" styleClass="field-label"/>
                            <TextArea fx:id="txtIssueDesc" promptText="Describe the issue..." styleClass="text-area" prefRowCount="3" wrapText="true"/>
                        </VBox>
                        <Button text="SUBMIT REPORT" onAction="#reportIssue" styleClass="btn-secondary"/>
                    </VBox>

                </VBox>
            </HBox>
        </ScrollPane>
    </center>
</BorderPane>
</StackPane>