<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.media.MediaView?>
<?import javafx.geometry.Insets?>

<StackPane styleClass="samurai-root" stylesheets="@/styles/style.css"
           xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="ma.ensa.khouribga.smartstay.LandingController">

    <!-- Cinematic video background -->
    <MediaView fx:id="bgVideo" fitWidth="1920" fitHeight="1080"
               preserveRatio="false" mouseTransparent="true"/>

    <!-- Dark vignette overlay -->
    <Region style="-fx-background-color: rgba(0,0,0,0.45);"/>

    <!-- Center content -->
    <VBox alignment="CENTER" spacing="32">

        <!-- Brand block -->
        <VBox alignment="CENTER" spacing="10">
            <Label text="侍"
                   style="-fx-font-size: 80px; -fx-text-fill: #cc1111;
                          -fx-opacity: 0.90;
                          -fx-effect: dropshadow(gaussian,rgba(139,0,0,0.80),30,0,0,0);"/>
            <Label text="SMARTSTAY"
                   style="-fx-font-size: 48px; -fx-font-weight: bold;
                          -fx-text-fill: #c5a059; -fx-letter-spacing: 10;
                          -fx-effect: dropshadow(gaussian,rgba(197,160,89,0.50),16,0,0,0);"/>
            <Label text="PROPERTY MANAGEMENT SYSTEM"
                   style="-fx-font-size: 13px; -fx-text-fill: #707070;
                          -fx-letter-spacing: 6;"/>

            <!-- Gold divider line -->
            <Region styleClass="gold-divider" maxWidth="220"
                    style="-fx-margin: 10 0 0 0;"/>
        </VBox>

        <!-- Tagline -->
        <Label text="智 Wisdom · 侍 Precision · 礼 Excellence"
               style="-fx-font-size: 14px; -fx-text-fill: #505050;
                      -fx-letter-spacing: 3;"/>

        <!-- Feature pills -->
        <HBox alignment="CENTER" spacing="20">
            <Label text="⛩  ROOMS"
                   style="-fx-font-size: 11px; -fx-text-fill: #c5a059;
                          -fx-font-weight: bold; -fx-letter-spacing: 2;
                          -fx-background-color: rgba(197,160,89,0.10);
                          -fx-border-color: rgba(197,160,89,0.30);
                          -fx-border-width: 1; -fx-border-radius: 20;
                          -fx-background-radius: 20; -fx-padding: 6 16;"/>
            <Label text="📋  RESERVATIONS"
                   style="-fx-font-size: 11px; -fx-text-fill: #c5a059;
                          -fx-font-weight: bold; -fx-letter-spacing: 2;
                          -fx-background-color: rgba(197,160,89,0.10);
                          -fx-border-color: rgba(197,160,89,0.30);
                          -fx-border-width: 1; -fx-border-radius: 20;
                          -fx-background-radius: 20; -fx-padding: 6 16;"/>
            <Label text="💴  PAYROLL"
                   style="-fx-font-size: 11px; -fx-text-fill: #c5a059;
                          -fx-font-weight: bold; -fx-letter-spacing: 2;
                          -fx-background-color: rgba(197,160,89,0.10);
                          -fx-border-color: rgba(197,160,89,0.30);
                          -fx-border-width: 1; -fx-border-radius: 20;
                          -fx-background-radius: 20; -fx-padding: 6 16;"/>
            <Label text="👥  STAFF"
                   style="-fx-font-size: 11px; -fx-text-fill: #c5a059;
                          -fx-font-weight: bold; -fx-letter-spacing: 2;
                          -fx-background-color: rgba(197,160,89,0.10);
                          -fx-border-color: rgba(197,160,89,0.30);
                          -fx-border-width: 1; -fx-border-radius: 20;
                          -fx-background-radius: 20; -fx-padding: 6 16;"/>
        </HBox>

        <!-- CTA button -->
        <Button text="ENTER THE PORTAL"
                onAction="#handleEnter"
                style="-fx-font-size: 15px; -fx-padding: 14 44;"
                styleClass="btn-primary, samurai-button"/>

        <!-- Light mode pill -->
        <Button text="☀ Light Mode" onAction="#handleThemeToggle"
                styleClass="btn-theme"/>

    </VBox>

    <!-- Bottom credit -->
    <Label text="SmartStay PMS · Khouribga Edition · © 2025"
           style="-fx-font-size: 10px; -fx-text-fill: #303030; -fx-letter-spacing: 1; -fx-padding: 0 0 18 0;"
           StackPane.alignment="BOTTOM_CENTER"/>

</StackPane>
