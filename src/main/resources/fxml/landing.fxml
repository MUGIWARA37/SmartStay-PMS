<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.media.MediaView?>
<?import javafx.geometry.Insets?>

<StackPane styleClass="samurai-root" stylesheets="@/styles/style.css"
           xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="ma.ensa.khouribga.smartstay.LandingController">

    <!-- Cinematic video background -->
    <MediaView fx:id="bgVideo" fitWidth="1920" fitHeight="1080"
               preserveRatio="false" mouseTransparent="true"/>

    <!-- Theme-aware vignette overlay -->
    <Region styleClass="landing-overlay"/>

    <!-- Center content -->
    <VBox alignment="CENTER" spacing="32">

        <!-- Brand block -->
        <VBox alignment="CENTER" spacing="10">
            <Label text="侍"
                   styleClass="landing-brand-kanji"/>
            <Label text="SMARTSTAY"
                   styleClass="landing-brand-title"/>
            <Label text="PROPERTY MANAGEMENT SYSTEM"
                   styleClass="landing-brand-subtitle"/>

            <!-- Gold divider line -->
            <Region styleClass="gold-divider" maxWidth="220">
                <VBox.margin>
                    <Insets top="10"/>
                </VBox.margin>
            </Region>
        </VBox>

        <!-- Tagline -->
        <Label text="智 Wisdom · 侍 Precision · 礼 Excellence"
               styleClass="landing-tagline"/>

        <!-- Feature pills -->
        <HBox alignment="CENTER" spacing="20">
            <Label text="⛩  ROOMS"
                   styleClass="landing-feature-pill"/>
            <Label text="📋  RESERVATIONS"
                   styleClass="landing-feature-pill"/>
            <Label text="💴  PAYROLL"
                   styleClass="landing-feature-pill"/>
            <Label text="👥  STAFF"
                   styleClass="landing-feature-pill"/>
        </HBox>

        <!-- CTA button -->
        <Button text="ENTER THE PORTAL"
                onAction="#handleEnter"
                styleClass="btn-primary samurai-button landing-enter-button"/>

        <!-- Light mode pill -->
        <Button fx:id="btnThemeToggle" text="☀ Light" onAction="#handleThemeToggle"
                styleClass="btn-theme"/>

    </VBox>

    <!-- Bottom credit -->
    <Label text="SmartStay PMS · Khouribga Edition · © 2025"
           styleClass="landing-footer"
           StackPane.alignment="BOTTOM_CENTER"/>

</StackPane>
