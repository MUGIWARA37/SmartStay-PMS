<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<BorderPane styleClass="interior-root" stylesheets="@/styles/samurai.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ma.ensa.khouribga.smartstay.staff.ReceptionController">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" styleClass="glass-box" style="-fx-padding: 20; -fx-background-radius: 0; -fx-border-radius: 0; -fx-border-width: 0 0 1px 0;">
            <Label text="侍" styleClass="kanji-large" style="-fx-font-size: 32px; -fx-text-fill: #8b0000;"/>
            <VBox>
                <Label text="FRONT DESK COMMAND" styleClass="app-title" style="-fx-font-size: 24px;"/>
                <Label text="GUEST LOGISTICS &amp; OPERATIONS" styleClass="app-subtitle" style="-fx-font-size: 12px;"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="👤 PROFILE &amp; COMM LINK" onMouseClicked="#goToProfile" styleClass="btn-secondary"/>
            <Button text="☀ Light" onAction="#handleThemeToggle" styleClass="btn-theme" maxWidth="Infinity"/>
                <Button text="LOGOUT" onAction="#handleLogout" styleClass="btn-logout, btn-secondary"/>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" styleClass="scroll-pane" style="-fx-padding: 20;">
            <HBox spacing="25" alignment="TOP_CENTER">
                
                <VBox spacing="25" minWidth="350" maxWidth="400">
                    
                    <VBox styleClass="glass-box" spacing="15">
                        <Label text="Walk-In Registration" styleClass="section-title" style="-fx-font-size: 20px;"/>
                        <Label text="Process unregistered arrivals." styleClass="label-muted"/>
                        <Button text="NEW WALK-IN" onAction="#doWalkIn" styleClass="btn-primary" maxWidth="Infinity"/>
                    </VBox>

                    <VBox styleClass="glass-box" spacing="15">
                        <Label text="Dispatch Cleaning" styleClass="section-title" style="-fx-font-size: 20px;"/>
                        <HBox spacing="10">
                            <TextField fx:id="txtCleanRoom" promptText="Room #" styleClass="text-field" HBox.hgrow="ALWAYS"/>
                            <Button text="REQUEST" onAction="#requestCleaning" styleClass="btn-secondary"/>
                        </HBox>
                    </VBox>

                    <VBox styleClass="glass-box" spacing="15">
                        <Label text="Dispatch Maintenance" styleClass="section-title" style="-fx-font-size: 20px;"/>
                        
                        <HBox spacing="10">
                            <VBox spacing="5" HBox.hgrow="ALWAYS">
                                <Label text="TARGET ROOM" styleClass="field-label"/>
                                <TextField fx:id="txtMaintRoom" promptText="e.g. 104" styleClass="text-field"/>
                            </VBox>
                            <VBox spacing="5" HBox.hgrow="ALWAYS">
                                <Label text="HAZARD TYPE" styleClass="field-label"/>
                                <ComboBox fx:id="cmbMaintCategory" promptText="Select..." styleClass="combo-box" maxWidth="Infinity"/>
                            </VBox>
                        </HBox>

                        <VBox spacing="5">
                            <Label text="SITUATION REPORT" styleClass="field-label"/>
                            <TextArea fx:id="txtMaintDesc" promptText="Describe the physical damage or issue..." styleClass="text-area" prefRowCount="2" wrapText="true"/>
                        </VBox>
                        
                        <Button text="DISPATCH CREW" onAction="#dispatchMaintenance" styleClass="samurai-button" maxWidth="Infinity"/>
                    </VBox>
                </VBox>

                <VBox spacing="15" HBox.hgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT" spacing="15" styleClass="glass-box" style="-fx-padding: 15;">
                        <Label text="Today's Logistics" styleClass="section-title"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <TextField fx:id="txtSearch" promptText="🔍  Search code, guest, room…" styleClass="text-field" prefWidth="260" onKeyReleased="#filterReservations"/>
                        <Button text="REFRESH" onAction="#loadReservations" styleClass="btn-secondary"/>
                    </HBox>

                    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="scroll-pane" minHeight="450">
                        <FlowPane fx:id="resGrid" styleClass="data-grid"/>
                    </ScrollPane>
                    
                    <HBox spacing="15" alignment="CENTER_RIGHT" styleClass="glass-box" style="-fx-padding: 15;">
                        <Button text="CHECK IN SELECTED" onAction="#doCheckIn" styleClass="btn-success"/>
                        <Button text="CHECK OUT SELECTED" onAction="#doCheckOut" styleClass="btn-primary"/>
                    </HBox>
                </VBox>

            </HBox>
        </ScrollPane>
    </center>
</BorderPane>