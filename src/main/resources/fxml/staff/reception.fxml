<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.media.MediaView?>
<?import javafx.scene.layout.StackPane?>

<StackPane styleClass="video-root" stylesheets="@/styles/samurai.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ma.ensa.khouribga.smartstay.staff.ReceptionController">
    <MediaView fx:id="bgMediaView" mouseTransparent="true"
               preserveRatio="false" style="-fx-smooth: true;"/>
    <BorderPane styleClass="interior-root">

    <!-- ═══════════════════════════ SIDEBAR -->
    <left>
        <VBox styleClass="sidebar" prefWidth="220" spacing="4">
            <VBox styleClass="sidebar-header" alignment="CENTER" spacing="4">
                <Label text="侍" styleClass="sidebar-logo"/>
                <Label text="SMARTSTAY" styleClass="app-title"/>
                <Label text="RECEPTION" styleClass="app-subtitle"/>
                <Label text="智 Wisdom · 侍 Precision" styleClass="sidebar-sub-kanji"/>
            </VBox>

            <Button text="🏠  Front Desk"   styleClass="nav-button-active" maxWidth="Infinity"/>
            <Button text="📋  Reservations" styleClass="nav-button"        maxWidth="Infinity"/>

            <Region VBox.vgrow="ALWAYS"/>

            <HBox alignment="CENTER" style="-fx-padding: 0 16 8 16;">
                <Button text="☀ Light" onAction="#handleThemeToggle" styleClass="btn-theme" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
            </HBox>

            <VBox spacing="8" style="-fx-padding: 0 16 16 16;">
                <HBox alignment="CENTER" spacing="10" style="-fx-cursor: hand;" onMouseClicked="#goToProfile">
                    <StackPane styleClass="avatar-circle" prefWidth="36" prefHeight="36">
                        <Label text="RC" styleClass="avatar-initials" style="-fx-font-size: 14px;"/>
                    </StackPane>
                    <VBox alignment="CENTER_LEFT">
                        <Label text="Receptionist" style="-fx-text-fill: #e0e0e0; -fx-font-weight: bold; -fx-font-size: 12px;"/>
                        <Label text="View Profile →" styleClass="label-muted" style="-fx-font-size: 10px;"/>
                    </VBox>
                </HBox>
                <Button text="LOGOUT" onAction="#handleLogout" styleClass="btn-logout" maxWidth="Infinity"/>
            </VBox>
        </VBox>
    </left>

    <!-- ═══════════════════════════ HEADER BAR -->
    <top>
        <HBox styleClass="header-bar" alignment="CENTER_LEFT" spacing="16">
            <Label text="FRONT DESK COMMAND" styleClass="breadcrumb-label"/>
            <Button text="Operations"  styleClass="header-nav-link-active"/>
            <Button text="Logistics"   styleClass="header-nav-link"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="GUEST LOGISTICS &amp; OPERATIONS" styleClass="label-muted"/>
        </HBox>
    </top>

    <!-- ═══════════════════════════ CENTER -->
    <center>
        <ScrollPane fitToWidth="true" styleClass="scroll-pane" style="-fx-padding: 20;">
            <HBox spacing="25" alignment="TOP_CENTER" style="-fx-padding: 20;">

                <!-- Left panel: walk-in + dispatch -->
                <VBox spacing="20" minWidth="340" maxWidth="390">

                    <VBox styleClass="glass-box" spacing="15">
                        <Label text="Walk-In Registration" styleClass="section-title" style="-fx-font-size: 18px;"/>
                        <Label text="Process unregistered arrivals." styleClass="label-muted"/>
                        <Button text="NEW WALK-IN" onAction="#doWalkIn" styleClass="btn-primary" maxWidth="Infinity"/>
                    </VBox>

                    <VBox styleClass="glass-box" spacing="15">
                        <Label text="Dispatch Cleaning" styleClass="section-title" style="-fx-font-size: 18px;"/>
                        <HBox spacing="10">
                            <TextField fx:id="txtCleanRoom" promptText="Room #" styleClass="text-field" HBox.hgrow="ALWAYS"/>
                            <Button text="REQUEST" onAction="#requestCleaning" styleClass="btn-secondary"/>
                        </HBox>
                    </VBox>

                    <VBox styleClass="glass-box" spacing="15">
                        <Label text="Dispatch Maintenance" styleClass="section-title" style="-fx-font-size: 18px;"/>
                        <HBox spacing="10">
                            <VBox spacing="5" HBox.hgrow="ALWAYS">
                                <Label text="TARGET ROOM" styleClass="field-label"/>
                                <TextField fx:id="txtMaintRoom" promptText="e.g. 104" styleClass="text-field"/>
                            </VBox>
                            <VBox spacing="5" HBox.hgrow="ALWAYS">
                                <Label text="HAZARD TYPE" styleClass="field-label"/>
                                <ComboBox fx:id="cmbMaintCategory" promptText="Select..." styleClass="combo-box" maxWidth="Infinity"/>
                            </VBox>
                        </HBox>
                        <VBox spacing="5">
                            <Label text="SITUATION REPORT" styleClass="field-label"/>
                            <TextArea fx:id="txtMaintDesc" promptText="Describe the issue..." styleClass="text-area" prefRowCount="2" wrapText="true"/>
                        </VBox>
                        <Button text="DISPATCH CREW" onAction="#dispatchMaintenance" styleClass="btn-primary" maxWidth="Infinity"/>
                    </VBox>
                </VBox>

                <!-- Right panel: reservation grid -->
                <VBox spacing="0" HBox.hgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT" spacing="15" styleClass="toolbar-bar">
                        <Label text="Today's Logistics" styleClass="section-title" style="-fx-font-size: 16px;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <TextField fx:id="txtSearch" promptText="🔍  Search code, guest, room…"
                                   styleClass="text-field" prefWidth="240" onKeyReleased="#filterReservations"/>
                        <Button text="REFRESH" onAction="#loadReservations" styleClass="btn-secondary"/>
                    </HBox>

                    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="scroll-pane" minHeight="400">
                        <FlowPane fx:id="resGrid" styleClass="data-grid"/>
                    </ScrollPane>

                    <HBox spacing="15" alignment="CENTER_RIGHT" styleClass="toolbar-bar">
                        <Button text="CHECK IN SELECTED"  onAction="#doCheckIn"  styleClass="btn-success"/>
                        <Button text="CHECK OUT SELECTED" onAction="#doCheckOut" styleClass="btn-primary"/>
                    </HBox>
                </VBox>

            </HBox>
        </ScrollPane>
    </center>
</BorderPane>
</StackPane>
