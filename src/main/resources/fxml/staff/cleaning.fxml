<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.media.MediaView?>

<StackPane styleClass="video-root" stylesheets="@/styles/style.css"
           xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="ma.ensa.khouribga.smartstay.staff.CleaningController">
    <MediaView fx:id="bgMediaView" mouseTransparent="true" preserveRatio="false"/>

    <BorderPane styleClass="interior-root" prefWidth="1100" prefHeight="700">

        <!-- ══════════════════════════════════ SIDEBAR -->
        <left>
            <VBox styleClass="sidebar" prefWidth="220" spacing="0">

                <VBox styleClass="sidebar-header" alignment="CENTER" spacing="4"
                      style="-fx-padding: 28 16 24 16;">
                    <Label text="侍" styleClass="sidebar-logo"/>
                    <Label text="SMARTSTAY"  styleClass="app-title"/>
                    <Label text="CLEANING"   styleClass="app-subtitle"/>
                    <Label text="智 Wisdom · 侍 Precision"
                           styleClass="sidebar-sub-kanji"/>
                </VBox>

                <!--
                    Cleaning staff sees their task list (loadTasks) and Settings.
                    The "My Tasks" item is always the active view for this role.
                -->
                <Button text="🧹  My Tasks"
                        onAction="#loadTasks"
                        styleClass="nav-button-active" maxWidth="Infinity"/>
                <Button text="⚙  Settings"
                        onAction="#goToProfile"
                        styleClass="nav-button" maxWidth="Infinity"/>

                <Region VBox.vgrow="ALWAYS"/>

                <HBox style="-fx-padding: 0 16 10 16;">
                    <Button text="☀ Light" onAction="#handleThemeToggle"
                            styleClass="btn-theme" maxWidth="Infinity"
                            HBox.hgrow="ALWAYS"/>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="10"
                      style="-fx-padding: 10 16 8 16; -fx-cursor: hand;"
                      onMouseClicked="#goToProfile">
                    <StackPane styleClass="avatar-circle" prefWidth="34" prefHeight="34">
                        <Label text="CL" styleClass="avatar-initials"
                               style="-fx-font-size: 13px;"/>
                    </StackPane>
                    <VBox alignment="CENTER_LEFT" spacing="1">
                        <Label fx:id="welcomeLabel" text="Cleaning Staff"
                               style="-fx-text-fill:#e0e0e0;-fx-font-weight:bold;-fx-font-size:12px;"/>
                        <Label text="View Profile →"
                               styleClass="label-muted" style="-fx-font-size: 10px;"/>
                    </VBox>
                </HBox>
                <VBox style="-fx-padding: 4 16 20 16;">
                    <Button text="LOGOUT" styleClass="btn-logout"
                            onAction="#onLogout" maxWidth="Infinity"/>
                </VBox>
            </VBox>
        </left>

        <!-- ══════════════════════════════════ HEADER -->
        <top>
            <HBox styleClass="header-bar" alignment="CENTER_LEFT" spacing="16">
                <Label text="CLEANING DASHBOARD" styleClass="breadcrumb-label"/>
                <Label text="·" styleClass="label-muted"/>
                <Label text="My Tasks"
                       style="-fx-text-fill:#cc2222;-fx-font-size:11px;
                              -fx-font-weight:bold;-fx-letter-spacing:2;"/>
                <Region HBox.hgrow="ALWAYS"/>
            </HBox>
        </top>

        <!-- ══════════════════════════════════ CENTER -->
        <center>
            <VBox spacing="0" styleClass="content-area"
                  style="-fx-padding: 20;">
                <!-- Filter toolbar -->
                <HBox alignment="CENTER_LEFT" spacing="12"
                      styleClass="toolbar-bar">
                    <Label text="MY CLEANING TASKS" styleClass="section-title"
                           style="-fx-font-size: 16px;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <ComboBox fx:id="statusFilter" promptText="Filter by status"
                              styleClass="combo-box"/>
                    <Button text="Apply"   onAction="#applyFilter"
                            styleClass="btn-secondary"/>
                    <Button text="Refresh" onAction="#loadTasks"
                            styleClass="btn-secondary"/>
                </HBox>

                <!-- Task table -->
                <TableView fx:id="taskTable" VBox.vgrow="ALWAYS"
                           styleClass="table-view">
                    <columns>
                        <TableColumn fx:id="colRoom"      text="Room"      prefWidth="90"/>
                        <TableColumn fx:id="colPriority"  text="Priority"  prefWidth="100"/>
                        <TableColumn fx:id="colStatus"    text="Status"    prefWidth="130"/>
                        <TableColumn fx:id="colNote"      text="Note"      prefWidth="280"/>
                        <TableColumn fx:id="colCreated"   text="Created"   prefWidth="160"/>
                        <TableColumn fx:id="colCompleted" text="Completed" prefWidth="160"/>
                    </columns>
                    <placeholder>
                        <Label text="No cleaning tasks assigned."
                               styleClass="label-muted"/>
                    </placeholder>
                </TableView>

                <!-- Action toolbar -->
                <HBox spacing="12" alignment="CENTER_LEFT"
                      styleClass="toolbar-bar">
                    <Label text="Update selected task:"
                           styleClass="form-label"/>
                    <Button text="Start (IN PROGRESS)"
                            onAction="#markInProgress"
                            styleClass="btn-secondary"/>
                    <Button text="Mark DONE"
                            onAction="#markDone"
                            styleClass="btn-success"/>
                </HBox>
            </VBox>
        </center>
    </BorderPane>
</StackPane>
