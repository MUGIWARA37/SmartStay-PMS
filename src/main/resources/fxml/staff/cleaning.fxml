<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.media.MediaView?>
<?import javafx.scene.layout.StackPane?>

<StackPane styleClass="video-root" stylesheets="@/styles/samurai.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ma.ensa.khouribga.smartstay.staff.CleaningController">
    <MediaView fx:id="bgMediaView" mouseTransparent="true"
               preserveRatio="false" style="-fx-smooth: true;"/>
    <BorderPane styleClass="interior-root" prefWidth="1100" prefHeight="700">

    <!-- ═══════════ SIDEBAR -->
    <left>
        <VBox styleClass="sidebar" prefWidth="220" spacing="4">
            <VBox styleClass="sidebar-header" alignment="CENTER" spacing="4">
                <Label text="侍" styleClass="sidebar-logo"/>
                <Label text="SMARTSTAY" styleClass="app-title"/>
                <Label text="CLEANING" styleClass="app-subtitle"/>
                <Label text="智 Wisdom · 侍 Precision" styleClass="sidebar-sub-kanji"/>
            </VBox>
            <Button text="🧹  My Tasks" styleClass="nav-button-active" maxWidth="Infinity"/>
            <Region VBox.vgrow="ALWAYS"/>
            <HBox alignment="CENTER" style="-fx-padding: 0 16 8 16;">
                <Button text="☀ Light" onAction="#handleThemeToggle" styleClass="btn-theme" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
            </HBox>
            <VBox spacing="8" style="-fx-padding: 0 16 16 16;">
                <HBox alignment="CENTER" spacing="10" style="-fx-cursor: hand;" onMouseClicked="#goToProfile">
                    <StackPane styleClass="avatar-circle" prefWidth="36" prefHeight="36">
                        <Label text="CL" styleClass="avatar-initials" style="-fx-font-size: 14px;"/>
                    </StackPane>
                    <VBox alignment="CENTER_LEFT">
                        <Label fx:id="welcomeLabel" text="Staff" style="-fx-text-fill: #e0e0e0; -fx-font-weight: bold; -fx-font-size: 12px;"/>
                        <Label text="View Profile →" styleClass="label-muted" style="-fx-font-size: 10px;"/>
                    </VBox>
                </HBox>
                <Button text="LOGOUT" styleClass="btn-logout" onAction="#onLogout" maxWidth="Infinity"/>
            </VBox>
        </VBox>
    </left>

    <!-- ═══════════ HEADER BAR -->
    <top>
        <HBox styleClass="header-bar" alignment="CENTER_LEFT" spacing="16">
            <Label text="CLEANING DASHBOARD" styleClass="breadcrumb-label"/>
            <Button text="Tasks" styleClass="header-nav-link-active"/>
            <Region HBox.hgrow="ALWAYS"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="0" styleClass="content-area" style="-fx-padding: 20;">
            <!-- Toolbar -->
            <HBox alignment="CENTER_LEFT" spacing="12" styleClass="toolbar-bar" style="-fx-margin: 0 0 16 0;">
                <Label text="MY CLEANING TASKS" styleClass="section-title" style="-fx-font-size: 18px;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <ComboBox fx:id="statusFilter" promptText="Filter by status" styleClass="combo-box"/>
                <Button text="Apply"   styleClass="btn-secondary" onAction="#applyFilter"/>
                <Button text="Refresh" styleClass="btn-secondary" onAction="#loadTasks"/>
            </HBox>
            <TableView fx:id="taskTable" VBox.vgrow="ALWAYS" styleClass="table-view">
                <columns>
                    <TableColumn fx:id="colRoom"      text="Room"      prefWidth="90"/>
                    <TableColumn fx:id="colPriority"  text="Priority"  prefWidth="100"/>
                    <TableColumn fx:id="colStatus"    text="Status"    prefWidth="130"/>
                    <TableColumn fx:id="colNote"      text="Note"      prefWidth="280"/>
                    <TableColumn fx:id="colCreated"   text="Created"   prefWidth="160"/>
                    <TableColumn fx:id="colCompleted" text="Completed" prefWidth="160"/>
                </columns>
                <placeholder><Label text="No cleaning tasks assigned." styleClass="label-muted"/></placeholder>
            </TableView>
            <HBox spacing="12" alignment="CENTER_LEFT" styleClass="toolbar-bar">
                <Label text="Update selected task:" styleClass="form-label"/>
                <Button text="Start (IN PROGRESS)" styleClass="btn-secondary" onAction="#markInProgress"/>
                <Button text="Mark DONE" styleClass="btn-success" onAction="#markDone"/>
            </HBox>
        </VBox>
    </center>
</BorderPane>
</StackPane>
