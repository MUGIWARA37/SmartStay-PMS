<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.media.MediaView?>

<StackPane styleClass="video-root" stylesheets="@/styles/samurai.css"
           xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="ma.ensa.khouribga.smartstay.staff.MaintenanceController">
    <MediaView fx:id="bgMediaView" mouseTransparent="true" preserveRatio="false"/>

    <BorderPane styleClass="interior-root" prefWidth="1100" prefHeight="700">

        <!-- ══════════════════════════════════ SIDEBAR -->
        <left>
            <VBox styleClass="sidebar" prefWidth="220" spacing="0">

                <VBox styleClass="sidebar-header" alignment="CENTER" spacing="4"
                      style="-fx-padding: 28 16 24 16;">
                    <Label text="侍" styleClass="sidebar-logo"/>
                    <Label text="SMARTSTAY"    styleClass="app-title"/>
                    <Label text="MAINTENANCE"  styleClass="app-subtitle"/>
                    <Label text="智 Wisdom · 侍 Precision"
                           styleClass="sidebar-sub-kanji"/>
                </VBox>

                <!--
                    Maintenance staff: My Tickets is the main view (loadTasks),
                    Settings goes to profile.
                -->
                <Button text="🛠  My Tickets"
                        onAction="#loadTasks"
                        styleClass="nav-button-active" maxWidth="Infinity"/>
                <Button text="⚙  Settings"
                        onAction="#goToProfile"
                        styleClass="nav-button" maxWidth="Infinity"/>

                <Region VBox.vgrow="ALWAYS"/>

                <HBox style="-fx-padding: 0 16 10 16;">
                    <Button text="☀ Light" onAction="#handleThemeToggle"
                            styleClass="btn-theme" maxWidth="Infinity"
                            HBox.hgrow="ALWAYS"/>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="10"
                      style="-fx-padding: 10 16 8 16; -fx-cursor: hand;"
                      onMouseClicked="#goToProfile">
                    <StackPane styleClass="avatar-circle" prefWidth="34" prefHeight="34">
                        <Label text="MT" styleClass="avatar-initials"
                               style="-fx-font-size: 13px;"/>
                    </StackPane>
                    <VBox alignment="CENTER_LEFT" spacing="1">
                        <Label fx:id="welcomeLabel" text="Maintenance Staff"
                               style="-fx-text-fill:#e0e0e0;-fx-font-weight:bold;-fx-font-size:12px;"/>
                        <Label text="View Profile →"
                               styleClass="label-muted" style="-fx-font-size: 10px;"/>
                    </VBox>
                </HBox>
                <VBox style="-fx-padding: 4 16 20 16;">
                    <Button text="LOGOUT" styleClass="btn-logout"
                            onAction="#onLogout" maxWidth="Infinity"/>
                </VBox>
            </VBox>
        </left>

        <!-- ══════════════════════════════════ HEADER -->
        <top>
            <HBox styleClass="header-bar" alignment="CENTER_LEFT" spacing="16">
                <Label text="MAINTENANCE DASHBOARD" styleClass="breadcrumb-label"/>
                <Label text="·" styleClass="label-muted"/>
                <Label text="My Tickets"
                       style="-fx-text-fill:#cc2222;-fx-font-size:11px;
                              -fx-font-weight:bold;-fx-letter-spacing:2;"/>
                <Region HBox.hgrow="ALWAYS"/>
            </HBox>
        </top>

        <!-- ══════════════════════════════════ CENTER -->
        <center>
            <HBox spacing="20" styleClass="content-area" style="-fx-padding: 20;">

                <!-- Task table column -->
                <VBox spacing="0" HBox.hgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT" spacing="10"
                          styleClass="toolbar-bar">
                        <Label text="MY MAINTENANCE TASKS"
                               styleClass="section-title"
                               style="-fx-font-size: 15px;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <ComboBox fx:id="statusFilter" promptText="Filter"
                                  styleClass="combo-box"/>
                        <Button text="Apply"   onAction="#applyFilter"
                                styleClass="btn-secondary"/>
                        <Button text="Refresh" onAction="#loadTasks"
                                styleClass="btn-secondary"/>
                    </HBox>

                    <TableView fx:id="taskTable" VBox.vgrow="ALWAYS"
                               styleClass="table-view">
                        <columns>
                            <TableColumn fx:id="colRoom"     text="Room"        prefWidth="80"/>
                            <TableColumn fx:id="colTitle"    text="Title"       prefWidth="180"/>
                            <TableColumn fx:id="colPriority" text="Priority"    prefWidth="100"/>
                            <TableColumn fx:id="colStatus"   text="Status"      prefWidth="130"/>
                            <TableColumn fx:id="colDesc"     text="Description" prefWidth="220"/>
                            <TableColumn fx:id="colCreated"  text="Created"     prefWidth="150"/>
                        </columns>
                        <placeholder>
                            <Label text="No maintenance tasks assigned."
                                   styleClass="label-muted"/>
                        </placeholder>
                    </TableView>

                    <HBox spacing="12" styleClass="toolbar-bar">
                        <Button text="Mark IN PROGRESS"
                                onAction="#markInProgress"
                                styleClass="btn-secondary"/>
                        <Button text="Mark RESOLVED"
                                onAction="#markResolved"
                                styleClass="btn-success"/>
                    </HBox>
                </VBox>

                <!-- Report new issue panel -->
                <VBox spacing="14" prefWidth="300">
                    <VBox styleClass="section-box" spacing="12">
                        <Label text="REPORT NEW ISSUE"
                               styleClass="section-title"
                               style="-fx-font-size: 15px;"/>
                        <Region styleClass="gold-divider"/>
                        <Label text="ROOM" styleClass="form-label"/>
                        <ComboBox fx:id="roomCombo" maxWidth="Infinity"
                                  styleClass="combo-box"
                                  promptText="Select room"/>
                        <Label text="TITLE" styleClass="form-label"/>
                        <TextField fx:id="titleField" styleClass="form-field"
                                   promptText="Issue title" maxWidth="Infinity"/>
                        <Label text="PRIORITY" styleClass="form-label"/>
                        <ComboBox fx:id="priorityCombo" maxWidth="Infinity"
                                  styleClass="combo-box"/>
                        <Label text="DESCRIPTION" styleClass="form-label"/>
                        <TextArea fx:id="descField" prefHeight="80"
                                  wrapText="true"
                                  promptText="Describe the issue…"
                                  styleClass="text-area"/>
                        <Label fx:id="formError" text=""
                               styleClass="label-red" wrapText="true"/>
                        <Button text="Report Issue" onAction="#reportIssue"
                                styleClass="btn-primary" maxWidth="Infinity"/>
                    </VBox>
                </VBox>
            </HBox>
        </center>
    </BorderPane>
</StackPane>
