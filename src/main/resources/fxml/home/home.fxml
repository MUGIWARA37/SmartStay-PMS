<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="ma.ensa.khouribga.smartstay.home.HomeController"
            styleClass="interior-root"
            prefWidth="1280" prefHeight="800">

    <!-- ═══════════════════════════════════════════════════════ SIDEBAR -->
    <left>
        <VBox styleClass="sidebar" prefWidth="220" spacing="4">
            <padding><Insets top="0" right="0" bottom="0" left="0"/></padding>

            <!-- Brand -->
            <VBox styleClass="sidebar-header" alignment="CENTER">
                <padding><Insets top="28" right="16" bottom="24" left="16"/></padding>
                <Label text="智" styleClass="sidebar-logo"/>
                <Label text="SmartStay" style="-fx-font-size:15px; -fx-font-weight:bold; -fx-text-fill: #e2c97e;"/>
                <Label text="GUEST PORTAL" style="-fx-font-size:9px; -fx-text-fill:#888; -fx-letter-spacing:2;"/>
            </VBox>

            <!-- Nav items (guest has just one active screen) -->
            <Button text="🏠  Browse Rooms" styleClass="nav-button-active" maxWidth="Infinity"/>
            <Button text="📋  My Bookings"  styleClass="nav-button"        maxWidth="Infinity"/>

            <Region VBox.vgrow="ALWAYS"/>

            <!-- Logout -->
            <Button fx:id="btnLogout" text="⬅  Sign Out" styleClass="btn-logout"
                    maxWidth="Infinity" onAction="#handleLogout"/>
            <padding><Insets bottom="16"/></padding>
        </VBox>
    </left>

    <!-- ═══════════════════════════════════════════════════════ CENTER -->
    <center>
        <VBox>

            <!-- ── Header bar ── -->
            <HBox styleClass="header-bar" alignment="CENTER_LEFT" spacing="12">
                <padding><Insets top="0" right="24" bottom="0" left="24"/></padding>
                <VBox spacing="2">
                    <Label fx:id="welcomeLabel" text="Welcome back" styleClass="welcome-label"/>
                    <Label text="Find and book your perfect room" styleClass="label-muted"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <ProgressIndicator fx:id="spinner" prefWidth="24" prefHeight="24" visible="false"/>
                <Label fx:id="lblStatus" styleClass="label-muted"/>
            </HBox>

            <!-- ── Filter bar ── -->
            <HBox styleClass="card" spacing="16" alignment="CENTER_LEFT">
                <padding><Insets top="14" right="20" bottom="14" left="20"/></padding>
                <margin><Insets top="16" right="20" bottom="0" left="20"/></margin>

                <Label text="Type:" styleClass="form-label"/>
                <ComboBox fx:id="cbRoomType" prefWidth="160" styleClass="combo-box"/>

                <Separator orientation="VERTICAL"/>

                <Label text="Max price / night:" styleClass="form-label"/>
                <Slider fx:id="priceSlider" prefWidth="180"/>
                <Label fx:id="priceLabel" styleClass="label-muted" prefWidth="180"/>

                <Separator orientation="VERTICAL"/>

                <Label text="Check-in:" styleClass="form-label"/>
                <DatePicker fx:id="dpCheckIn" prefWidth="140" styleClass="date-picker"/>

                <Label text="Check-out:" styleClass="form-label"/>
                <DatePicker fx:id="dpCheckOut" prefWidth="140" styleClass="date-picker"/>

                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="btnSearch" text="🔍  Search" styleClass="btn-primary" onAction="#applyFilters"/>
            </HBox>

            <!-- ── Section title ── -->
            <HBox>
                <padding><Insets top="20" right="20" bottom="8" left="20"/></padding>
                <Label text="Available Rooms" styleClass="section-title"/>
            </HBox>

            <!-- ── Room grid ── -->
            <ScrollPane styleClass="scroll-pane" fitToWidth="true" VBox.vgrow="ALWAYS">
                <FlowPane fx:id="roomGrid" styleClass="content-area"
                          hgap="18" vgap="18" prefWrapLength="900">
                    <padding><Insets top="8" right="20" bottom="20" left="20"/></padding>
                </FlowPane>
            </ScrollPane>

        </VBox>
    </center>

</BorderPane>
