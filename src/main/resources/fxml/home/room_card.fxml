<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="cardRoot" prefWidth="320.0" styleClass="room-card" stylesheets="@/styles/style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ma.ensa.khouribga.smartstay.home.RoomCardController">

    <StackPane prefHeight="180.0" styleClass="card-image-container">
        <Label fx:id="imagePlaceholder" styleClass="image-placeholder" text="No Image Available" />
        <ImageView fx:id="roomImageView" fitHeight="180.0" fitWidth="320.0" preserveRatio="false" />
    </StackPane>

    <VBox spacing="12.0">
        <padding>
            <Insets bottom="18.0" left="18.0" right="18.0" top="18.0" />
        </padding>

        <HBox alignment="CENTER_LEFT">
            <Label text="Room " styleClass="card-label-muted" style="-fx-font-size: 14px;"/>
            <Label fx:id="lblRoomNumber" styleClass="card-title" text="000" style="-fx-font-size: 18px;"/>
            <Region HBox.hgrow="ALWAYS" />
            <Label fx:id="lblStatus" styleClass="status-badge" text="Status" />
        </HBox>

        <Label fx:id="lblRoomType" styleClass="card-subtitle" text="Room Type" style="-fx-font-size: 14px;"/>

        <HBox alignment="CENTER_RIGHT">
            <padding>
                <Insets top="12.0" />
            </padding>
            <Button fx:id="btnDetails" mnemonicParsing="false" onAction="#handleDetails" styleClass="btn-outline" text="View Details" />
        </HBox>
    </VBox>
</VBox>
