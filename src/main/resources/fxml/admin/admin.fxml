<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.chart.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.media.MediaView?>

<StackPane styleClass="video-root" stylesheets="@/styles/samurai.css"
           xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="ma.ensa.khouribga.smartstay.admin.AdminController">
    <MediaView fx:id="bgMediaView" mouseTransparent="true" preserveRatio="false"/>

    <BorderPane styleClass="interior-root">

        <!-- ══════════════════════════════════════ SIDEBAR -->
        <left>
            <VBox styleClass="sidebar" prefWidth="250" spacing="0">

                <!-- Brand -->
                <VBox styleClass="sidebar-header" alignment="CENTER" spacing="4"
                      style="-fx-padding: 28 16 24 16;">
                    <Label text="侍" styleClass="sidebar-logo"/>
                    <Label text="SMARTSTAY"   styleClass="app-title"/>
                    <Label text="ADMINISTRATOR" styleClass="app-subtitle"/>
                    <Label text="智 Wisdom · 侍 Precision" styleClass="sidebar-sub-kanji"/>
                </VBox>

                <!--
                    Each nav button calls navToX() in AdminController.
                    navToX() does: mainTabPane.getSelectionModel().select(N)
                    and updates the active button style + headerTabLabel text.
                -->
                <Button fx:id="navBtnOverview"     text="⛩  Dashboard"
                        onAction="#navToOverview"
                        styleClass="nav-button-active" maxWidth="Infinity"/>
                <Button fx:id="navBtnRooms"        text="🏯  Room Mastery"
                        onAction="#navToRooms"
                        styleClass="nav-button" maxWidth="Infinity"/>
                <Button fx:id="navBtnReservations" text="📋  Guest Scrolls"
                        onAction="#navToReservations"
                        styleClass="nav-button" maxWidth="Infinity"/>
                <Button fx:id="navBtnPayroll"      text="💴  Financial Katana"
                        onAction="#navToPayroll"
                        styleClass="nav-button" maxWidth="Infinity"/>
                <Button fx:id="navBtnStaff"        text="👥  Zen Inventory"
                        onAction="#navToStaff"
                        styleClass="nav-button" maxWidth="Infinity"/>
                <Button fx:id="navBtnRevenue"      text="📊  Revenue Chart"
                        onAction="#navToRevenue"
                        styleClass="nav-button" maxWidth="Infinity"/>

                <Region VBox.vgrow="ALWAYS"/>

                <!-- Theme toggle pill -->
                <HBox style="-fx-padding: 0 16 10 16;">
                    <Button fx:id="btnThemeToggle" text="☀ Light"
                            onAction="#handleThemeToggle"
                            styleClass="btn-theme" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                </HBox>

                <!-- User row — click opens profile -->
                <HBox alignment="CENTER_LEFT" spacing="10"
                      style="-fx-padding: 10 16 8 16; -fx-cursor: hand;"
                      onMouseClicked="#goToProfile">
                    <StackPane styleClass="avatar-circle" prefWidth="36" prefHeight="36">
                        <Label text="AD" styleClass="avatar-initials" style="-fx-font-size: 14px;"/>
                    </StackPane>
                    <VBox alignment="CENTER_LEFT" spacing="1">
                        <Label text="System Admin"
                               style="-fx-text-fill: #e0e0e0; -fx-font-weight: bold; -fx-font-size: 13px;"/>
                        <Label text="View Profile →"
                               styleClass="label-muted" style="-fx-font-size: 10px;"/>
                    </VBox>
                </HBox>

                <VBox style="-fx-padding: 4 16 20 16;">
                    <Button text="LOGOUT" onAction="#handleLogout"
                            styleClass="btn-logout" maxWidth="Infinity"/>
                </VBox>
            </VBox>
        </left>

        <!-- ══════════════════════════════════════ HEADER -->
        <top>
            <HBox styleClass="header-bar" alignment="CENTER_LEFT" spacing="16">
                <Label text="IMPERIAL PORTAL" styleClass="breadcrumb-label"/>
                <Label text="·" styleClass="label-muted"/>
                <Label fx:id="headerTabLabel" text="Overview"
                       style="-fx-text-fill: #cc2222; -fx-font-size: 11px;
                              -fx-font-weight: bold; -fx-letter-spacing: 2;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="System Status:" styleClass="label-muted"/>
                <Label text="ONLINE" styleClass="badge, badge-available"/>
            </HBox>
        </top>

        <!-- ══════════════════════════════════════ CENTER -->
        <center>
            <VBox styleClass="content-area" spacing="0">
                <!--
                    Tab headers are zero-height — sidebar is the sole navigation.
                    mainTabPane is @FXML-injected so AdminController can call
                    mainTabPane.getSelectionModel().select(N)
                -->
                <TabPane fx:id="mainTabPane" VBox.vgrow="ALWAYS"
                         styleClass="tab-pane" tabClosingPolicy="UNAVAILABLE"
                         style="-fx-tab-min-height:0;-fx-tab-max-height:0;">

                    <!-- ── TAB 0 · OVERVIEW ─────────────────────────────── -->
                    <Tab text="">
                        <ScrollPane fitToWidth="true" styleClass="scroll-pane">
                            <VBox spacing="20" style="-fx-padding: 24 28 28 28;">

                                <HBox alignment="CENTER_LEFT" spacing="16">
                                    <Label text="Command Center"
                                           styleClass="section-title"
                                           style="-fx-font-size: 26px;"/>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Button text="⟳  Refresh"
                                            onAction="#refreshOverview"
                                            styleClass="btn-secondary"/>
                                    <Button text="📊  Revenue"
                                            onAction="#loadRevenueChart"
                                            styleClass="btn-primary"/>
                                </HBox>

                                <!-- 4 stat cards with Stitch accent bars -->
                                <HBox spacing="20">
                                    <VBox styleClass="stat-card-gold"
                                          HBox.hgrow="ALWAYS" spacing="8">
                                        <Label text="AVAILABLE ROOMS"
                                               styleClass="stat-card-label"/>
                                        <Label fx:id="statAvailable" text="0"
                                               styleClass="stat-card-value"
                                               style="-fx-text-fill:#c5a059;"/>
                                        <Label text="Operational"
                                               styleClass="stat-card-trend"/>
                                    </VBox>
                                    <VBox styleClass="stat-card-red"
                                          HBox.hgrow="ALWAYS" spacing="8">
                                        <Label text="OCCUPIED ROOMS"
                                               styleClass="stat-card-label"/>
                                        <Label fx:id="statOccupied" text="0"
                                               styleClass="stat-card-value"
                                               style="-fx-text-fill:#ff3333;"/>
                                        <Label text="Live occupancy"
                                               styleClass="stat-card-trend"
                                               style="-fx-text-fill:#808080;"/>
                                    </VBox>
                                    <VBox styleClass="stat-card-green"
                                          HBox.hgrow="ALWAYS" spacing="8">
                                        <Label text="ACTIVE BOOKINGS"
                                               styleClass="stat-card-label"/>
                                        <Label fx:id="statActiveRes" text="0"
                                               styleClass="stat-card-value"
                                               style="-fx-text-fill:#2ecc71;"/>
                                        <Label text="Live reservations"
                                               styleClass="stat-card-trend"/>
                                    </VBox>
                                    <VBox styleClass="stat-card-blue"
                                          HBox.hgrow="ALWAYS" spacing="8">
                                        <Label text="MAINTENANCE ALERTS"
                                               styleClass="stat-card-label"/>
                                        <Label fx:id="statMaint" text="0"
                                               styleClass="stat-card-value"
                                               style="-fx-text-fill:#3498db;"/>
                                        <Label text="Pending tasks"
                                               styleClass="stat-card-trend"
                                               style="-fx-text-fill:#3498db;"/>
                                    </VBox>
                                </HBox>

                                <!-- Charts row 1 -->
                                <HBox spacing="20">
                                    <VBox styleClass="glass-box" HBox.hgrow="ALWAYS"
                                          spacing="8" alignment="CENTER">
                                        <Label text="Room Status Distribution"
                                               styleClass="chart-title"/>
                                        <PieChart fx:id="roomStatusChart" animated="true"
                                                  labelsVisible="true" legendVisible="true"
                                                  legendSide="BOTTOM" prefHeight="280"
                                                  style="-fx-background-color:transparent;"/>
                                    </VBox>
                                    <VBox styleClass="glass-box" HBox.hgrow="ALWAYS"
                                          spacing="8" alignment="CENTER">
                                        <Label text="Monthly Guest Check-ins"
                                               styleClass="chart-title"/>
                                        <BarChart fx:id="clientChart" animated="false"
                                                  legendVisible="false" prefHeight="280"
                                                  style="-fx-background-color:transparent;">
                                            <xAxis><CategoryAxis fx:id="clientXAxis"
                                                    style="-fx-tick-label-fill:#808080;-fx-font-size:10px;"/></xAxis>
                                            <yAxis><NumberAxis fx:id="clientYAxis" label="Guests"
                                                    style="-fx-tick-label-fill:#808080;"/></yAxis>
                                        </BarChart>
                                    </VBox>
                                </HBox>

                                <!-- Charts row 2 -->
                                <HBox spacing="20">
                                    <VBox styleClass="glass-box" prefWidth="380"
                                          spacing="8" alignment="CENTER">
                                        <Label text="Staff Activity Status"
                                               styleClass="chart-title"/>
                                        <PieChart fx:id="staffStatusChart" animated="true"
                                                  labelsVisible="true" legendVisible="true"
                                                  legendSide="BOTTOM" prefHeight="260"
                                                  style="-fx-background-color:transparent;"/>
                                    </VBox>
                                    <VBox styleClass="glass-box" HBox.hgrow="ALWAYS"
                                          spacing="16" alignment="CENTER">
                                        <Label text="Total Staff Active"
                                               styleClass="chart-title"/>
                                        <VBox styleClass="stat-card-blue" alignment="CENTER"
                                              spacing="6" maxWidth="Infinity">
                                            <Label text="ACTIVE STAFF"
                                                   styleClass="stat-card-label"/>
                                            <Label fx:id="statCleaning" text="—"
                                                   styleClass="stat-card-value"
                                                   style="-fx-font-size:36px;-fx-text-fill:#3498db;"/>
                                        </VBox>
                                    </VBox>
                                </HBox>

                            </VBox>
                        </ScrollPane>
                    </Tab>

                    <!-- ── TAB 1 · ROOMS ─────────────────────────────────── -->
                    <Tab text="">
                        <VBox spacing="0">
                            <HBox spacing="15" alignment="CENTER_LEFT"
                                  styleClass="toolbar-bar">
                                <Label text="Room Mastery"
                                       styleClass="section-title"
                                       style="-fx-font-size:15px;"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <ComboBox fx:id="roomStatusFilter"
                                          promptText="Filter Status…"
                                          styleClass="combo-box"/>
                                <Button text="Refresh" onAction="#loadAllRooms"
                                        styleClass="btn-secondary"/>
                                <ComboBox fx:id="roomStatusEdit"
                                          promptText="Change Status To…"
                                          styleClass="combo-box"/>
                                <Button text="UPDATE SELECTED"
                                        onAction="#updateRoomStatus"
                                        styleClass="btn-primary"/>
                            </HBox>
                            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                                        styleClass="scroll-pane">
                                <FlowPane fx:id="roomGrid" styleClass="data-grid"/>
                            </ScrollPane>
                        </VBox>
                    </Tab>

                    <!-- ── TAB 2 · RESERVATIONS ─────────────────────────── -->
                    <Tab text="">
                        <VBox spacing="0">
                            <HBox spacing="12" alignment="CENTER_LEFT"
                                  styleClass="toolbar-bar">
                                <Label text="Guest Scrolls"
                                       styleClass="section-title"
                                       style="-fx-font-size:15px;"/>
                                <ComboBox fx:id="resStatusFilter"
                                          promptText="Status…"
                                          styleClass="combo-box"/>
                                <Label text="From:" styleClass="label-muted"/>
                                <DatePicker fx:id="resDateFrom"
                                            styleClass="date-picker" prefWidth="138"/>
                                <Label text="To:" styleClass="label-muted"/>
                                <DatePicker fx:id="resDateTo"
                                            styleClass="date-picker" prefWidth="138"/>
                                <Button text="🔍 APPLY"
                                        onAction="#filterReservations"
                                        styleClass="btn-secondary"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Button text="CHECK-IN"
                                        onAction="#doCheckIn"
                                        styleClass="btn-success"/>
                                <Button text="CHECK-OUT"
                                        onAction="#doCheckOut"
                                        styleClass="btn-primary"/>
                            </HBox>
                            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                                        styleClass="scroll-pane">
                                <FlowPane fx:id="resGrid" styleClass="data-grid"/>
                            </ScrollPane>
                        </VBox>
                    </Tab>

                    <!-- ── TAB 3 · PAYROLL ───────────────────────────────── -->
                    <Tab text="">
                        <VBox spacing="0">
                            <HBox spacing="15" alignment="CENTER_LEFT"
                                  styleClass="toolbar-bar">
                                <Label text="Financial Katana"
                                       styleClass="section-title"
                                       style="-fx-font-size:15px;"/>
                                <Label text="Period:" styleClass="form-label"/>
                                <DatePicker fx:id="payPeriodStart"
                                            styleClass="date-picker"/>
                                <Label text="to" styleClass="label-muted"/>
                                <DatePicker fx:id="payPeriodEnd"
                                            styleClass="date-picker"/>
                                <Button text="Generate"
                                        onAction="#generatePayroll"
                                        styleClass="btn-primary"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Button text="MARK PAID"
                                        onAction="#markPayrollPaid"
                                        styleClass="btn-success"/>
                            </HBox>
                            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                                        styleClass="scroll-pane">
                                <FlowPane fx:id="payrollGrid" styleClass="data-grid"/>
                            </ScrollPane>
                        </VBox>
                    </Tab>

                    <!-- ── TAB 4 · STAFF ─────────────────────────────────── -->
                    <Tab text="">
                        <VBox spacing="0">
                            <HBox spacing="15" alignment="CENTER_LEFT"
                                  styleClass="toolbar-bar">
                                <Label text="Zen Inventory"
                                       styleClass="section-title"
                                       style="-fx-font-size:15px;"/>
                                <ComboBox fx:id="staffRoleFilter"
                                          promptText="Role…" styleClass="combo-box"/>
                                <ComboBox fx:id="staffStatusFilter"
                                          promptText="Status…" styleClass="combo-box"/>
                                <Button text="Refresh" onAction="#loadAllStaff"
                                        styleClass="btn-secondary"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Button text="ACTIVATE"
                                        onAction="#activateStaff"
                                        styleClass="btn-success"/>
                                <Button text="DEACTIVATE"
                                        onAction="#deactivateStaff"
                                        styleClass="btn-danger"/>
                            </HBox>
                            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                                        styleClass="scroll-pane">
                                <FlowPane fx:id="staffGrid" styleClass="data-grid"/>
                            </ScrollPane>
                        </VBox>
                    </Tab>

                    <!-- ── TAB 5 · REVENUE ───────────────────────────────── -->
                    <Tab text="">
                        <VBox spacing="0">
                            <HBox spacing="15" alignment="CENTER_LEFT"
                                  styleClass="toolbar-bar">
                                <Label text="Revenue Chart"
                                       styleClass="section-title"
                                       style="-fx-font-size:15px;"/>
                                <Label text="Year:" styleClass="form-label"/>
                                <ComboBox fx:id="revenueYearPicker"
                                          promptText="Year…" styleClass="combo-box"/>
                                <Button text="Load" onAction="#loadRevenueChart"
                                        styleClass="btn-primary"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label fx:id="revenueTotalLabel" text="Annual Total: —"
                                       styleClass="card-header-text"
                                       style="-fx-font-size:15px;"/>
                            </HBox>
                            <BarChart fx:id="revenueChart" VBox.vgrow="ALWAYS"
                                      styleClass="revenue-chart"
                                      animated="false" legendVisible="false">
                                <xAxis><CategoryAxis fx:id="revenueXAxis" label="Month"
                                        style="-fx-tick-label-fill:#a0a0a0;"/></xAxis>
                                <yAxis><NumberAxis fx:id="revenueYAxis" label="Revenue (MAD)"
                                        style="-fx-tick-label-fill:#a0a0a0;"/></yAxis>
                            </BarChart>
                        </VBox>
                    </Tab>

                </TabPane>
            </VBox>
        </center>

    </BorderPane>
</StackPane>
