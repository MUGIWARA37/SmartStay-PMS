<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.chart.*?>
<?import javafx.geometry.Insets?>

<BorderPane styleClass="interior-root" stylesheets="@/styles/samurai.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ma.ensa.khouribga.smartstay.admin.AdminController">

    <left>
        <VBox styleClass="sidebar" prefWidth="250" spacing="10">
            <VBox alignment="CENTER" spacing="10" style="-fx-padding: 0 0 30 0;">
                <Label text="侍" styleClass="kanji-large" style="-fx-font-size: 36px; -fx-text-fill: #8b0000;"/>
                <Label text="SMARTSTAY" styleClass="app-title" style="-fx-font-size: 20px;"/>
                <Label text="ADMINISTRATOR" styleClass="app-subtitle" style="-fx-font-size: 10px;"/>
            </VBox>
            
            <Button text="⛩ Dashboard" styleClass="nav-button, nav-button-active" maxWidth="Infinity"/>
            
            <Region VBox.vgrow="ALWAYS"/>
            
            <VBox alignment="CENTER" spacing="15" style="-fx-padding: 20;">
                <HBox alignment="CENTER" spacing="10" style="-fx-cursor: hand;" onMouseClicked="#goToProfile">
                    <StackPane styleClass="avatar-circle" prefWidth="40" prefHeight="40">
                        <Label text="AD" styleClass="avatar-initials" style="-fx-font-size: 16px;"/>
                    </StackPane>
                    <VBox alignment="CENTER_LEFT">
                        <Label text="System Admin" style="-fx-text-fill: #e0e0e0; -fx-font-weight: bold;"/>
                        <Label text="View Profile" styleClass="label-muted" style="-fx-font-size: 10px;"/>
                    </VBox>
                </HBox>
                <Button text="LOGOUT" onAction="#handleLogout" styleClass="btn-secondary, btn-logout" maxWidth="Infinity"/>
            </VBox>
        </VBox>
    </left>

    <center>
        <VBox styleClass="content-area" spacing="20" style="-fx-padding: 30;">
            
            <HBox alignment="CENTER_LEFT" spacing="20">
                <Label text="Imperial Command Center" styleClass="section-title" style="-fx-font-size: 28px;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="System Status: " styleClass="label-muted"/>
                <Label text="ONLINE" styleClass="badge, badge-available"/>
            </HBox>

            <TabPane VBox.vgrow="ALWAYS" styleClass="tab-pane" tabClosingPolicy="UNAVAILABLE">
                
                <Tab text="⛩ OVERVIEW">
                    <VBox spacing="20" style="-fx-padding: 20 0 0 0;">
                        <HBox spacing="20">
                            <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" alignment="CENTER" spacing="10">
                                <Label text="Available Rooms" styleClass="stat-card-label, label-muted"/>
                                <Label fx:id="statAvailable" text="0" styleClass="stat-card-value" style="-fx-font-size: 36px; -fx-text-fill: #2ecc71; -fx-font-weight: bold;"/>
                            </VBox>
                            <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" alignment="CENTER" spacing="10">
                                <Label text="Occupied Rooms" styleClass="stat-card-label, label-muted"/>
                                <Label fx:id="statOccupied" text="0" styleClass="stat-card-value" style="-fx-font-size: 36px; -fx-text-fill: #e74c3c; -fx-font-weight: bold;"/>
                            </VBox>
                            <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" alignment="CENTER" spacing="10">
                                <Label text="Active Bookings" styleClass="stat-card-label, label-muted"/>
                                <Label fx:id="statActiveRes" text="0" styleClass="stat-card-value" style="-fx-font-size: 36px; -fx-text-fill: #c5a059; -fx-font-weight: bold;"/>
                            </VBox>
                            <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" alignment="CENTER" spacing="10">
                                <Label text="Maintenance Alerts" styleClass="stat-card-label, label-muted"/>
                                <Label fx:id="statMaint" text="0" styleClass="stat-card-value" style="-fx-font-size: 36px; -fx-text-fill: #f1c40f; -fx-font-weight: bold;"/>
                            </VBox>
                        </HBox>
                    </VBox>
                </Tab>

                <Tab text="🏯 ROOMS">
                    <VBox spacing="15" style="-fx-padding: 20 0 0 0;">
                        <HBox spacing="15" alignment="CENTER_LEFT" styleClass="glass-box" style="-fx-padding: 15;">
                            <ComboBox fx:id="roomStatusFilter" promptText="Filter Status..." styleClass="combo-box"/>
                            <Button text="Refresh Registry" onAction="#loadAllRooms" styleClass="btn-secondary"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <ComboBox fx:id="roomStatusEdit" promptText="Change Status To..." styleClass="combo-box"/>
                            <Button text="UPDATE SELECTED" onAction="#updateRoomStatus" styleClass="btn-primary"/>
                        </HBox>
                        
                        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="scroll-pane">
                            <FlowPane fx:id="roomGrid" styleClass="data-grid"/>
                        </ScrollPane>
                    </VBox>
                </Tab>

                <Tab text="📋 RESERVATIONS">
                    <VBox spacing="15" style="-fx-padding: 20 0 0 0;">
                        <HBox spacing="15" alignment="CENTER_LEFT" styleClass="glass-box" style="-fx-padding: 15;">
                            <ComboBox fx:id="resStatusFilter" promptText="Filter Status..." styleClass="combo-box"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button text="CHECK-IN SELECTED" onAction="#doCheckIn" styleClass="btn-success"/>
                            <Button text="CHECK-OUT SELECTED" onAction="#doCheckOut" styleClass="btn-primary"/>
                        </HBox>

                        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="scroll-pane">
                            <FlowPane fx:id="resGrid" styleClass="data-grid"/>
                        </ScrollPane>
                    </VBox>
                </Tab>

                <Tab text="💴 PAYROLL">
                    <VBox spacing="15" style="-fx-padding: 20 0 0 0;">
                        <HBox spacing="15" alignment="CENTER_LEFT" styleClass="glass-box" style="-fx-padding: 15;">
                            <Label text="Compute Period:" styleClass="form-label"/>
                            <DatePicker fx:id="payPeriodStart" styleClass="date-picker"/>
                            <Label text="to" styleClass="label-muted"/>
                            <DatePicker fx:id="payPeriodEnd" styleClass="date-picker"/>
                            <Button text="Generate Scrolls" onAction="#generatePayroll" styleClass="btn-primary"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button text="MARK SELECTED PAID" onAction="#markPayrollPaid" styleClass="btn-success"/>
                        </HBox>

                        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="scroll-pane">
                            <FlowPane fx:id="payrollGrid" styleClass="data-grid"/>
                        </ScrollPane>
                    </VBox>
                </Tab>


                <Tab text="👥 STAFF">
                    <VBox spacing="15" style="-fx-padding: 20 0 0 0;">
                        <HBox spacing="15" alignment="CENTER_LEFT" styleClass="glass-box" style="-fx-padding: 15;">
                            <ComboBox fx:id="staffRoleFilter" promptText="Filter Role..." styleClass="combo-box"/>
                            <ComboBox fx:id="staffStatusFilter" promptText="Filter Status..." styleClass="combo-box"/>
                            <Button text="Refresh Roster" onAction="#loadAllStaff" styleClass="btn-secondary"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button text="ACTIVATE SELECTED" onAction="#activateStaff" styleClass="btn-success"/>
                            <Button text="DEACTIVATE SELECTED" onAction="#deactivateStaff" styleClass="btn-primary"/>
                        </HBox>

                        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="scroll-pane">
                            <FlowPane fx:id="staffGrid" styleClass="data-grid"/>
                        </ScrollPane>
                    </VBox>
                </Tab>

                <Tab text="📊 REVENUE">
                    <VBox spacing="15" style="-fx-padding: 20 0 0 0;">
                        <HBox spacing="15" alignment="CENTER_LEFT" styleClass="glass-box" style="-fx-padding: 15;">
                            <Label text="Year:" styleClass="form-label"/>
                            <ComboBox fx:id="revenueYearPicker" promptText="Select Year..." styleClass="combo-box"/>
                            <Button text="Load Chart" onAction="#loadRevenueChart" styleClass="btn-primary"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label fx:id="revenueTotalLabel" text="Annual Total: —" styleClass="card-header-text" style="-fx-font-size: 16px;"/>
                        </HBox>

                        <BarChart fx:id="revenueChart" VBox.vgrow="ALWAYS" styleClass="revenue-chart"
                                  animated="false" legendVisible="false">
                            <xAxis>
                                <CategoryAxis fx:id="revenueXAxis" label="Month"
                                              style="-fx-tick-label-fill: #a0a0a0; -fx-text-fill: #a0a0a0;"/>
                            </xAxis>
                            <yAxis>
                                <NumberAxis fx:id="revenueYAxis" label="Revenue (MAD)"
                                            style="-fx-tick-label-fill: #a0a0a0; -fx-text-fill: #a0a0a0;"/>
                            </yAxis>
                        </BarChart>
                    </VBox>
                </Tab>

            </TabPane>
        </VBox>
    </center>
</BorderPane>