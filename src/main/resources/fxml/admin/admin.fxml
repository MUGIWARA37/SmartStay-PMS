<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.chart.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.media.MediaView?>

<StackPane styleClass="video-root" stylesheets="@/styles/style.css" 
           xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="ma.ensa.khouribga.smartstay.admin.AdminController">
    <MediaView fx:id="bgMediaView" mouseTransparent="true" preserveRatio="false"/>

    <BorderPane styleClass="interior-root">

        <!-- ══════════════════════════════════════ SIDEBAR -->
        <left>
            <VBox fx:id="sidebar" styleClass="sidebar" prefWidth="300" spacing="0">

                <!-- Brand -->
                <VBox styleClass="sidebar-header" alignment="CENTER" spacing="4"
                      style="-fx-padding: 28 16 24 16;">
                    <Label text="侍" styleClass="sidebar-logo"/>
                    <Label text="SMARTSTAY"   styleClass="app-title"/>
                    <Label text="ADMINISTRATOR" styleClass="app-subtitle"/>
                    <Label text="智 Wisdom · 侍 Precision" styleClass="sidebar-sub-kanji"/>
                </VBox>

                <!--
                    Each nav button calls navToX() in AdminController.
                    navToX() does: mainTabPane.getSelectionModel().select(N)
                    and updates the active button style + headerTabLabel text.
                -->
                <Button fx:id="navBtnOverview"     text="⛩  Dashboard"
                        onAction="#navToOverview"
                        styleClass="nav-button-active" maxWidth="Infinity"/>
                <Button fx:id="navBtnRooms"        text="🏯  Room Mastery"
                        onAction="#navToRooms"
                        styleClass="nav-button" maxWidth="Infinity"/>
                <Button fx:id="navBtnReservations" text="📋  Guest Scrolls"
                        onAction="#navToReservations"
                        styleClass="nav-button" maxWidth="Infinity"/>
                <Button fx:id="navBtnPayroll"      text="💴  Financial Katana"
                        onAction="#navToPayroll"
                        styleClass="nav-button" maxWidth="Infinity"/>
                <Button fx:id="navBtnStaff"        text="👥  Zen Inventory"
                        onAction="#navToStaff"
                        styleClass="nav-button" maxWidth="Infinity"/>
                <Button fx:id="navBtnRevenue"      text="📊  Revenue Chart"
                        onAction="#navToRevenue"
                        styleClass="nav-button" maxWidth="Infinity"/>

                <Region VBox.vgrow="ALWAYS"/>

                <!-- Theme toggle pill -->
                <HBox style="-fx-padding: 0 16 10 16;">
                    <Button fx:id="btnThemeToggle" text="☀ Light"
                            onAction="#handleThemeToggle"
                            styleClass="btn-theme" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                </HBox>

                <!-- User row — click opens profile -->
                <HBox alignment="CENTER_LEFT" spacing="10"
                      style="-fx-padding: 10 16 8 16; -fx-cursor: hand;"
                      onMouseClicked="#goToProfile">
                    <StackPane styleClass="avatar-circle" prefWidth="36" prefHeight="36">
                        <Label text="AD" styleClass="avatar-initials" style="-fx-font-size: 14px;"/>
                    </StackPane>
                    <VBox alignment="CENTER_LEFT" spacing="1">
                        <Label text="System Admin"
                               style="-fx-text-fill: #e0e0e0; -fx-font-weight: bold; -fx-font-size: 13px;"/>
                        <Label text="View Profile →"
                               styleClass="label-muted" style="-fx-font-size: 10px;"/>
                    </VBox>
                </HBox>

                <VBox style="-fx-padding: 4 16 20 16;">
                    <Button text="LOGOUT" onAction="#handleLogout"
                            styleClass="btn-logout" maxWidth="Infinity"/>
                </VBox>
            </VBox>
        </left>

        <!-- ══════════════════════════════════════ CENTER -->
        <center>
            <VBox styleClass="content-area" spacing="0">
                <!--
                    Tab headers are zero-height — sidebar is the sole navigation.
                    mainTabPane is @FXML-injected so AdminController can call
                    mainTabPane.getSelectionModel().select(N)
                -->
                <TabPane fx:id="mainTabPane" VBox.vgrow="ALWAYS"
                         styleClass="tab-pane" tabClosingPolicy="UNAVAILABLE"
                         style="-fx-tab-min-height:0;-fx-tab-max-height:0;">

                    <!-- ── TAB 0 · OVERVIEW ─────────────────────────────── -->
                    <Tab text="">
                        <ScrollPane fitToWidth="true" styleClass="scroll-pane">
                            <VBox spacing="20" style="-fx-padding: 28 32 32 32;">

                                <!-- Page header -->
                                <VBox spacing="6">
                                    <Label text="COMMAND CENTER"
                                           style="-fx-font-size:22px; -fx-font-weight:bold;
                                                  -fx-text-fill:#f0f0f0; -fx-letter-spacing:2;"/>
                                    <Label text="Precision management for the SmartStay Empire."
                                           styleClass="label-muted" style="-fx-font-size:13px;"/>
                                </VBox>

                                <!-- ── 4 STAT CARDS ── -->
                                <HBox spacing="16">

                                    <!-- Total Rooms — gold accent -->
                                    <VBox HBox.hgrow="ALWAYS" spacing="0"
                                          style="-fx-background-color:rgba(18,18,22,0.75);
                                                 -fx-background-radius:8; -fx-border-radius:8;
                                                 -fx-border-color:rgba(255,255,255,0.06);
                                                 -fx-border-width:1; -fx-padding:20;">
                                        <HBox alignment="CENTER_LEFT" spacing="8">
                                            <Region style="-fx-min-width:3;-fx-pref-width:3;-fx-min-height:48;
                                                           -fx-max-height:48;-fx-background-color:#C5A059;
                                                           -fx-background-radius:2;" HBox.hgrow="NEVER"/>
                                            <VBox spacing="6" HBox.hgrow="ALWAYS" style="-fx-padding:0 0 0 10;">
                                                <HBox alignment="CENTER_LEFT">
                                                    <Label text="TOTAL ROOMS" styleClass="stat-card-label"
                                                           HBox.hgrow="ALWAYS"/>
                                                    <Label text="🏨" style="-fx-font-size:18px;-fx-text-fill:#C5A059;"/>
                                                </HBox>
                                                <Label fx:id="statAvailable" text="—"
                                                       style="-fx-font-size:32px;-fx-font-weight:bold;-fx-text-fill:#ffffff;"/>
                                                <Label fx:id="lblStatAvailableSub" text="—"
                                                       style="-fx-font-size:10px;-fx-text-fill:#1e8449;"/>
                                            </VBox>
                                        </HBox>
                                    </VBox>

                                    <!-- Active Guests — crimson accent -->
                                    <VBox HBox.hgrow="ALWAYS" spacing="0"
                                          style="-fx-background-color:rgba(18,18,22,0.75);
                                                 -fx-background-radius:8; -fx-border-radius:8;
                                                 -fx-border-color:rgba(255,255,255,0.06);
                                                 -fx-border-width:1; -fx-padding:20;">
                                        <HBox alignment="CENTER_LEFT" spacing="8">
                                            <Region style="-fx-min-width:3;-fx-pref-width:3;-fx-min-height:48;
                                                           -fx-max-height:48;-fx-background-color:#FF3333;
                                                           -fx-background-radius:2;" HBox.hgrow="NEVER"/>
                                            <VBox spacing="6" HBox.hgrow="ALWAYS" style="-fx-padding:0 0 0 10;">
                                                <HBox alignment="CENTER_LEFT">
                                                    <Label text="ACTIVE GUESTS" styleClass="stat-card-label"
                                                           HBox.hgrow="ALWAYS"/>
                                                    <Label text="👥" style="-fx-font-size:18px;-fx-text-fill:#FF3333;"/>
                                                </HBox>
                                                <Label fx:id="statOccupied" text="—"
                                                       style="-fx-font-size:32px;-fx-font-weight:bold;-fx-text-fill:#ffffff;"/>
                                                <Label fx:id="lblStatOccupiedSub" text="—"
                                                       style="-fx-font-size:10px;-fx-text-fill:#888;"/>
                                            </VBox>
                                        </HBox>
                                    </VBox>

                                    <!-- Today's Check-ins — jade accent -->
                                    <VBox HBox.hgrow="ALWAYS" spacing="0"
                                          style="-fx-background-color:rgba(18,18,22,0.75);
                                                 -fx-background-radius:8; -fx-border-radius:8;
                                                 -fx-border-color:rgba(255,255,255,0.06);
                                                 -fx-border-width:1; -fx-padding:20;">
                                        <HBox alignment="CENTER_LEFT" spacing="8">
                                            <Region style="-fx-min-width:3;-fx-pref-width:3;-fx-min-height:48;
                                                           -fx-max-height:48;-fx-background-color:#1E8449;
                                                           -fx-background-radius:2;" HBox.hgrow="NEVER"/>
                                            <VBox spacing="6" HBox.hgrow="ALWAYS" style="-fx-padding:0 0 0 10;">
                                                <HBox alignment="CENTER_LEFT">
                                                    <Label text="TODAY'S CHECK-INS" styleClass="stat-card-label"
                                                           HBox.hgrow="ALWAYS"/>
                                                    <Label text="→" style="-fx-font-size:18px;-fx-text-fill:#1E8449;-fx-font-weight:bold;"/>
                                                </HBox>
                                                <Label fx:id="statActiveRes" text="—"
                                                       style="-fx-font-size:32px;-fx-font-weight:bold;-fx-text-fill:#ffffff;"/>
                                                <Label fx:id="lblStatActiveResSub" text="—"
                                                       style="-fx-font-size:10px;-fx-text-fill:#888;"/>
                                            </VBox>
                                        </HBox>
                                    </VBox>

                                    <!-- Monthly Revenue — gold accent -->
                                    <VBox HBox.hgrow="ALWAYS" spacing="0"
                                          style="-fx-background-color:rgba(18,18,22,0.75);
                                                 -fx-background-radius:8; -fx-border-radius:8;
                                                 -fx-border-color:rgba(255,255,255,0.06);
                                                 -fx-border-width:1; -fx-padding:20;">
                                        <HBox alignment="CENTER_LEFT" spacing="8">
                                            <Region style="-fx-min-width:3;-fx-pref-width:3;-fx-min-height:48;
                                                           -fx-max-height:48;-fx-background-color:#C5A059;
                                                           -fx-background-radius:2;" HBox.hgrow="NEVER"/>
                                            <VBox spacing="6" HBox.hgrow="ALWAYS" style="-fx-padding:0 0 0 10;">
                                                <HBox alignment="CENTER_LEFT">
                                                    <Label text="MONTHLY REVENUE" styleClass="stat-card-label"
                                                           HBox.hgrow="ALWAYS"/>
                                                    <Label text="💰" style="-fx-font-size:18px;-fx-text-fill:#C5A059;"/>
                                                </HBox>
                                                <Label fx:id="statMaint" text="—"
                                                       style="-fx-font-size:32px;-fx-font-weight:bold;-fx-text-fill:#ffffff;"/>
                                                <Label fx:id="lblStatRevenueSub" text="—"
                                                       style="-fx-font-size:10px;-fx-text-fill:#1e8449;"/>
                                            </VBox>
                                        </HBox>
                                    </VBox>

                                </HBox>

                                <!-- ── 3 CHARTS ROW ── -->
                                <HBox spacing="16">

                                    <!-- Room Status Donut -->
                                    <VBox HBox.hgrow="ALWAYS" spacing="12" styleClass="dashboard-chart-card">
                                        <HBox alignment="CENTER_LEFT" spacing="8" styleClass="dashboard-chart-title-row">
                                            <Region styleClass="dashboard-chart-dot,dot-room"/>
                                            <Label text="ROOM STATUS DISTRIBUTION" styleClass="dashboard-chart-title"/>
                                        </HBox>
                                        <PieChart fx:id="roomStatusChart" animated="true"
                                                  labelsVisible="false" legendVisible="true"
                                                  legendSide="BOTTOM" prefHeight="260"/>
                                    </VBox>

                                    <!-- Monthly Check-ins Bar Chart -->
                                    <VBox HBox.hgrow="ALWAYS" spacing="12" styleClass="dashboard-chart-card">
                                        <HBox alignment="CENTER_LEFT" spacing="8" styleClass="dashboard-chart-title-row">
                                            <Region styleClass="dashboard-chart-dot,dot-checkins"/>
                                            <Label text="MONTHLY CHECK-INS FLOW" styleClass="dashboard-chart-title"/>
                                        </HBox>
                                        <BarChart fx:id="clientChart" animated="false"
                                                  legendVisible="false" VBox.vgrow="ALWAYS"
                                                  prefHeight="260">
                                            <xAxis><CategoryAxis fx:id="clientXAxis"/></xAxis>
                                            <yAxis><NumberAxis fx:id="clientYAxis" label=""/></yAxis>
                                        </BarChart>
                                    </VBox>

                                    <!-- Legion Productivity -->
                                    <VBox HBox.hgrow="ALWAYS" spacing="12" styleClass="dashboard-chart-card">
                                        <HBox alignment="CENTER_LEFT" spacing="8" styleClass="dashboard-chart-title-row">
                                            <Region styleClass="dashboard-chart-dot,dot-staff"/>
                                            <Label text="LEGION PRODUCTIVITY" styleClass="dashboard-chart-title"/>
                                        </HBox>

                                        <!-- Staff donut chart -->
                                        <PieChart fx:id="staffStatusChart" animated="true"
                                                  labelsVisible="false" legendVisible="false"
                                                  prefHeight="180"/>

                                        <Region VBox.vgrow="ALWAYS"/>

                                        <!-- Active on-site row -->
                                        <VBox spacing="6">
                                            <HBox alignment="CENTER_LEFT">
                                                <Label text="ACTIVE ON-SITE" styleClass="chart-kpi-label" HBox.hgrow="ALWAYS"/>
                                                <Label fx:id="statCleaning" text="— Staff" styleClass="chart-kpi-value"/>
                                            </HBox>
                                            <ProgressBar fx:id="staffActiveBar" progress="0.7"
                                                          maxWidth="Infinity" prefHeight="5"
                                                          styleClass="chart-progress-primary"/>
                                            <HBox alignment="CENTER_LEFT">
                                                <Label text="PENDING TASKS" styleClass="chart-kpi-label" HBox.hgrow="ALWAYS"/>
                                                <Label text="28 Active" styleClass="chart-kpi-value"/>
                                            </HBox>
                                            <ProgressBar progress="0.45"
                                                          maxWidth="Infinity" prefHeight="5"
                                                          styleClass="chart-progress-secondary"/>
                                        </VBox>
                                    </VBox>
                                </HBox>

                                <!-- ── LIVE RESERVATION STREAM TABLE ── -->
                                <VBox style="-fx-background-color:rgba(10,10,14,0.55);
                                             -fx-background-radius:8; -fx-border-radius:8;
                                             -fx-border-color:rgba(255,255,255,0.05);
                                             -fx-border-width:1;" spacing="0">

                                    <!-- Table header -->
                                    <HBox alignment="CENTER_LEFT"
                                          style="-fx-padding:16 24; -fx-border-color:rgba(255,255,255,0.05);
                                                 -fx-border-width:0 0 1 0;">
                                        <Label text="LIVE RESERVATION STREAM"
                                               style="-fx-font-size:11px;-fx-font-weight:bold;
                                                      -fx-text-fill:#ffffff;-fx-letter-spacing:2;"
                                               HBox.hgrow="ALWAYS"/>
                                        <Button text="VIEW ALL SCROLLS"
                                                onAction="#navToReservations"
                                                style="-fx-background-color:transparent;-fx-border-width:0;
                                                       -fx-text-fill:#cc2222;-fx-font-size:10px;
                                                       -fx-cursor:hand;-fx-font-weight:bold;"/>
                                    </HBox>

                                    <!-- Column headers -->
                                    <HBox style="-fx-padding:10 24;-fx-background-color:rgba(255,255,255,0.04);
                                                 -fx-border-color:rgba(255,255,255,0.05);-fx-border-width:0 0 1 0;">
                                        <Label text="GUEST SOVEREIGN"
                                               style="-fx-font-size:10px;-fx-text-fill:#666;-fx-letter-spacing:2;"
                                               minWidth="200"/>
                                        <Label text="CHAMBER"
                                               style="-fx-font-size:10px;-fx-text-fill:#666;-fx-letter-spacing:2;"
                                               minWidth="180"/>
                                        <Label text="DURATION"
                                               style="-fx-font-size:10px;-fx-text-fill:#666;-fx-letter-spacing:2;"
                                               minWidth="180" HBox.hgrow="ALWAYS"/>
                                        <Label text="OFFERING"
                                               style="-fx-font-size:10px;-fx-text-fill:#666;-fx-letter-spacing:2;"
                                               minWidth="120"/>
                                        <Label text="STATUS"
                                               style="-fx-font-size:10px;-fx-text-fill:#666;-fx-letter-spacing:2;"
                                               minWidth="100"/>
                                    </HBox>

                                    <!-- Live rows populated by controller -->
                                    <VBox fx:id="liveResRows" spacing="0"/>

                                </VBox>

                            </VBox>
                        </ScrollPane>
                    </Tab>

                    <!-- ── TAB 1 · ROOMS ─────────────────────────────────── -->
                    <Tab text="">
                        <VBox spacing="0">
                            <HBox spacing="15" alignment="CENTER_LEFT"
                                  styleClass="toolbar-bar">
                                <Label text="Room Mastery"
                                       styleClass="section-title"
                                       style="-fx-font-size:15px;"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <ComboBox fx:id="roomStatusFilter"
                                          promptText="Filter Status…"
                                          styleClass="combo-box"/>
                                <Button text="Refresh" onAction="#loadAllRooms"
                                        styleClass="btn-secondary"/>
                                <ComboBox fx:id="roomStatusEdit"
                                          promptText="Change Status To…"
                                          styleClass="combo-box"/>
                                <Button text="UPDATE SELECTED"
                                        onAction="#updateRoomStatus"
                                        styleClass="btn-primary"/>
                            </HBox>
                            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                                        styleClass="scroll-pane">
                                <FlowPane fx:id="roomGrid" styleClass="data-grid"/>
                            </ScrollPane>
                        </VBox>
                    </Tab>

                    <!-- ── TAB 2 · RESERVATIONS ─────────────────────────── -->
                    <Tab text="">
                        <VBox spacing="0">
                            <HBox spacing="12" alignment="CENTER_LEFT"
                                  styleClass="toolbar-bar">
                                <Label text="Guest Scrolls"
                                       styleClass="section-title"
                                       style="-fx-font-size:15px;"/>
                                <ComboBox fx:id="resStatusFilter"
                                          promptText="Status…"
                                          styleClass="combo-box"/>
                                <Label text="From:" styleClass="label-muted"/>
                                <DatePicker fx:id="resDateFrom"
                                            styleClass="date-picker" prefWidth="138"/>
                                <Label text="To:" styleClass="label-muted"/>
                                <DatePicker fx:id="resDateTo"
                                            styleClass="date-picker" prefWidth="138"/>
                                <Button text="🔍 APPLY"
                                        onAction="#filterReservations"
                                        styleClass="btn-secondary"/>
                                <Region HBox.hgrow="ALWAYS"/>
                            </HBox>
                            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                                        styleClass="scroll-pane">
                                <FlowPane fx:id="resGrid" styleClass="data-grid"/>
                            </ScrollPane>
                        </VBox>
                    </Tab>

                    <!-- ── TAB 3 · PAYROLL ───────────────────────────────── -->
                    <Tab text="">
                        <VBox spacing="0">
                            <HBox spacing="15" alignment="CENTER_LEFT"
                                  styleClass="toolbar-bar">
                                <Label text="Financial Katana"
                                       styleClass="section-title"
                                       style="-fx-font-size:15px;"/>
                                <Label text="Period:" styleClass="form-label"/>
                                <DatePicker fx:id="payPeriodStart"
                                            styleClass="date-picker"/>
                                <Label text="to" styleClass="label-muted"/>
                                <DatePicker fx:id="payPeriodEnd"
                                            styleClass="date-picker"/>
                                <Button text="Generate"
                                        onAction="#generatePayroll"
                                        styleClass="btn-primary"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Button text="MARK PAID"
                                        onAction="#markPayrollPaid"
                                        styleClass="btn-success"/>
                            </HBox>
                            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                                        styleClass="scroll-pane">
                                <FlowPane fx:id="payrollGrid" styleClass="data-grid"/>
                            </ScrollPane>
                        </VBox>
                    </Tab>

                    <!-- ── TAB 4 · STAFF ─────────────────────────────────── -->
                    <Tab text="">
                        <VBox spacing="0">
                            <!-- Filter toolbar -->
                            <HBox spacing="15" alignment="CENTER_LEFT"
                                  styleClass="toolbar-bar">
                                <Label text="Zen Inventory"
                                       styleClass="section-title"
                                       style="-fx-font-size:15px;"/>
                                <ComboBox fx:id="staffRoleFilter"
                                          promptText="Role…" styleClass="combo-box"/>
                                <ComboBox fx:id="staffStatusFilter"
                                          promptText="Status…" styleClass="combo-box"/>
                                <Button text="Refresh" onAction="#loadAllStaff"
                                        styleClass="btn-secondary"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Button text="ACTIVATE"
                                        onAction="#activateStaff"
                                        styleClass="btn-success"/>
                                <Button text="DEACTIVATE"
                                        onAction="#deactivateStaff"
                                        styleClass="btn-danger"/>
                            </HBox>

                            <!-- Staff card grid -->
                            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                                        styleClass="scroll-pane">
                                <FlowPane fx:id="staffGrid" styleClass="data-grid"/>
                            </ScrollPane>

                            <!-- Shift assignment toolbar -->
                            <HBox alignment="CENTER_LEFT" spacing="12"
                                  styleClass="toolbar-bar"
                                  style="-fx-border-width: 1px 0 0 0; -fx-padding: 14 20;">

                                <!-- Selection indicator -->
                                <VBox spacing="2">
                                    <Label text="SELECTED EMPLOYEE" styleClass="stat-card-label"/>
                                    <Label fx:id="lblSelectedStaff" text="None — click a card above"
                                           style="-fx-text-fill:#c5a059; -fx-font-size:13px; -fx-font-weight:bold;"/>
                                </VBox>

                                <Region style="-fx-min-width:1; -fx-pref-width:1; -fx-min-height:36;
                                               -fx-background-color: rgba(197,160,89,0.25);"/>

                                <!-- Shift picker -->
                                <VBox spacing="3" alignment="CENTER_LEFT">
                                    <Label text="ASSIGN SHIFT" styleClass="stat-card-label"/>
                                    <ComboBox fx:id="shiftPicker"
                                              promptText="Select shift…"
                                              styleClass="combo-box"
                                              minWidth="200"/>
                                </VBox>

                                <!-- Date picker -->
                                <VBox spacing="3" alignment="CENTER_LEFT">
                                    <Label text="DATE" styleClass="stat-card-label"/>
                                    <DatePicker fx:id="shiftDatePicker"
                                                styleClass="date-picker"
                                                minWidth="150"/>
                                </VBox>

                                <!-- Notes -->
                                <VBox spacing="3" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                                    <Label text="NOTES (OPTIONAL)" styleClass="stat-card-label"/>
                                    <TextField fx:id="shiftNotes"
                                               promptText="e.g. Cover for absence…"
                                               styleClass="text-field"/>
                                </VBox>

                                <!-- Action button -->
                                <VBox spacing="3" alignment="CENTER">
                                    <Label text="ACTION" styleClass="stat-card-label"/>
                                    <Button text="⚔  ASSIGN SHIFT"
                                            onAction="#assignShift"
                                            styleClass="btn-primary"
                                            minWidth="140"/>
                                </VBox>
                            </HBox>
                        </VBox>
                    </Tab>

                    <!-- ── TAB 5 · REVENUE ───────────────────────────────── -->
                    <Tab text="">
                        <VBox spacing="0">
                            <HBox spacing="15" alignment="CENTER_LEFT"
                                  styleClass="toolbar-bar">
                                <Label text="Revenue Chart"
                                       styleClass="section-title"
                                       style="-fx-font-size:15px;"/>
                                <Label text="Year:" styleClass="form-label"/>
                                <ComboBox fx:id="revenueYearPicker"
                                          promptText="Year…" styleClass="combo-box"/>
                                <Button text="Load" onAction="#loadRevenueChart"
                                        styleClass="btn-primary"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label fx:id="revenueTotalLabel" text="Annual Total: —"
                                       styleClass="card-header-text"
                                       style="-fx-font-size:15px;"/>
                            </HBox>
                            <BarChart fx:id="revenueChart" VBox.vgrow="ALWAYS"
                                      styleClass="revenue-chart"
                                      animated="false" legendVisible="false">
                                <xAxis><CategoryAxis fx:id="revenueXAxis" label="Month"/></xAxis>
                                <yAxis><NumberAxis fx:id="revenueYAxis" label="Revenue (MAD)"/></yAxis>
                            </BarChart>
                        </VBox>
                    </Tab>

                </TabPane>
            </VBox>
        </center>

    </BorderPane>
    <Button fx:id="btnSidebarToggle" text="⇤" onAction="#toggleSidebar"
            styleClass="sidebar-toggle-button"
            StackPane.alignment="TOP_LEFT"
            style="-fx-translate-x: 14; -fx-translate-y: 14;"/>
</StackPane>
